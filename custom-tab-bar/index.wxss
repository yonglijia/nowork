/**
 * 自定义底部导航栏样式
 * 清晰、圆润、舒适
 */

.tabBar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  height: 110rpx;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(44, 62, 80, 0.1);
  backdrop-filter: blur(16px);
}

.tabItem {
  flex: 1;
  height: 100%;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #9AA5B1;
  transition: all 0.2s ease;
}

.tabItem.active {
  background: #E3F2FD;
  color: #5C9BD6;
}

.tabIcon {
  font-size: 36rpx;
  line-height: 1;
}

.tabText {
  font-size: 20rpx;
  font-weight: 600;
}
