/**
 * 自定义底部导航栏样式
 * 柔和、治愈、圆润
 */

.tabBar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  height: 120rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(61, 90, 92, 0.1);
  backdrop-filter: blur(16px);
}

.tabItem {
  flex: 1;
  height: 100%;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #A0B5B7;
  transition: all 0.2s ease;
}

.tabItem.active {
  background: rgba(126, 189, 184, 0.15);
  color: #5A8A8D;
}

.tabIcon {
  font-size: 38rpx;
  line-height: 1;
}

.tabText {
  font-size: 22rpx;
  font-weight: 600;
}
