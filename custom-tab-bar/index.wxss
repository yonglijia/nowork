.tabBar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  height: 120rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(45, 212, 191, 0.16);
  box-shadow: 0 18rpx 40rpx rgba(17, 94, 89, 0.12);
  backdrop-filter: blur(16px);
}

.tabItem {
  flex: 1;
  height: 100%;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: rgba(17, 94, 89, 0.65);
}

.tabItem.active {
  background: linear-gradient(135deg, rgba(45, 212, 191, 0.22), rgba(52, 211, 153, 0.16));
  color: #0f766e;
}

.tabIcon {
  font-size: 38rpx;
  line-height: 1;
}

.tabText {
  font-size: 22rpx;
  font-weight: 900;
}

