/**
 * 全局设计规范 - 升级版
 * 风格：温暖治愈系 + 设计感
 * 色彩：柔和蓝、温暖黄、甜蜜粉、薄荷绿
 * 特点：精致渐变、丰富层级、韵律排版、微交互
 */

/* ==================== CSS 变量系统 ==================== */
:root {
  /* 主色系 */
  --color-primary-blue: #5C9BD6;
  --color-primary-blue-light: #E3F2FD;
  --color-primary-yellow: #FFD54F;
  --color-primary-pink: #F48FB1;
  --color-primary-mint: #80DEEA;
  
  /* 中性色 */
  --color-text-primary: #2C3E50;
  --color-text-secondary: #5D6D7E;
  --color-text-tertiary: #85929E;
  --color-text-light: #9AA5B1;
  
  /* 背景 */
  --color-bg-base: #F5F8FA;
  --color-bg-surface: #FFFFFF;
  
  /* 渐变 */
  --gradient-blue: linear-gradient(135deg, #5C9BD6 0%, #6BA3DC 100%);
  --gradient-yellow: linear-gradient(135deg, #FFE082 0%, #FFD54F 100%);
  --gradient-pink: linear-gradient(135deg, #F48FB1 0%, #EC407A 100%);
  --gradient-mint: linear-gradient(135deg, #80DEEA 0%, #4DD0E1 100%);
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-pill: 999rpx;
  
  /* 间距 */
  --spacing-xs: 4rpx;
  --spacing-sm: 8rpx;
  --spacing-md: 12rpx;
  --spacing-lg: 16rpx;
  --spacing-xl: 20rpx;
  --spacing-2xl: 24rpx;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
  --shadow-md: 0 4rpx 12rpx rgba(44, 62, 80, 0.08);
  --shadow-lg: 0 6rpx 20rpx rgba(92, 155, 214, 0.15);
}

/* ==================== 全局基础 ==================== */
page {
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  background: var(--color-bg-base);
  color: var(--color-text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

.safePage {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* ==================== 卡片系统 ==================== */
.cardSurface {
  background: var(--color-bg-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.cardSurface:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

.pill {
  border-radius: var(--radius-pill);
}

/* ==================== 按钮系统 ==================== */
.btnClean::after {
  border: none;
}

/* 主按钮 */
.btnPrimary,
.btnMintPrimary {
  background: var(--gradient-blue);
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 16rpx rgba(92, 155, 214, 0.25);
  border: none;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btnPrimary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(92, 155, 214, 0.15);
}

/* 幽灵按钮 */
.btnGhost,
.btnMintGhost {
  background: rgba(92, 155, 214, 0.08);
  border: 1.5rpx solid rgba(92, 155, 214, 0.2);
  color: var(--color-primary-blue);
  font-weight: 600;
  border-radius: var(--radius-lg);
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btnGhost:active {
  background: rgba(92, 155, 214, 0.15);
  transform: scale(0.97);
}

/* 文字按钮 */
.btnText {
  background: transparent;
  color: var(--color-primary-blue);
  font-weight: 500;
  font-size: 26rpx;
  padding: 12rpx 16rpx;
  border: none;
  transition: opacity 0.2s ease;
}

.btnText:active {
  opacity: 0.7;
}

/* ==================== 排版系统 ==================== */
.titleLarge {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.titleMedium {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.titleSmall {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.bodyText {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  letter-spacing: 0.2rpx;
}

.hintText {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
}

.captionText {
  font-size: 22rpx;
  color: var(--color-text-light);
  line-height: 1.4;
}

/* ==================== 标签系统 ==================== */
.tag {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-pill);
  background: rgba(92, 155, 214, 0.12);
  border: 1.5rpx solid rgba(92, 155, 214, 0.25);
  color: var(--color-primary-blue);
  font-size: 22rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.tag.active {
  background: var(--color-primary-blue);
  border-color: var(--color-primary-blue);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.3);
}

.tag.pink {
  background: rgba(244, 143, 177, 0.12);
  border-color: rgba(244, 143, 177, 0.25);
  color: var(--color-primary-pink);
}

.tag.yellow {
  background: rgba(255, 208, 79, 0.15);
  border-color: rgba(255, 208, 79, 0.3);
  color: #F57F17;
}

.tag.mint {
  background: rgba(128, 222, 234, 0.12);
  border-color: rgba(128, 222, 234, 0.25);
  color: #00838F;
}

/* ==================== 输入框系统 ==================== */
.inputField,
input {
  width: 100%;
  padding: 14rpx 16rpx;
  font-size: 26rpx;
  background: rgba(92, 155, 214, 0.06);
  border-radius: var(--radius-md);
  color: var(--color-text-primary);
  box-sizing: border-box;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
  transition: all 0.2s ease;
}

input:focus {
  border-color: var(--color-primary-blue);
  background: rgba(92, 155, 214, 0.1);
}

input::placeholder {
  color: var(--color-text-light);
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(92, 155, 214, 0.1), rgba(92, 155, 214, 0.3), rgba(92, 155, 214, 0.1));
  margin: var(--spacing-lg) 0;
}

/* ==================== 弹窗样式 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(2rpx);
}

.modalContent {
  width: calc(100% - 48rpx);
  max-width: 600rpx;
  background: var(--color-bg-surface);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(44, 62, 80, 0.15);
}

.modalTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.modalDesc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.modalActions {
  display: flex;
  gap: var(--spacing-md);
  margin-top: 24rpx;
}

.modalBtn {
  flex: 1;
  padding: 16rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  transition: all 0.2s ease;
}

.modalBtn.confirm {
  background: var(--gradient-blue);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.25);
}

.modalBtn.cancel {
  background: rgba(92, 155, 214, 0.08);
  color: var(--color-primary-blue);
}

/* ==================== 列表项系统 ==================== */
.listItem {
  display: flex;
  align-items: center;
  padding: 16rpx;
  gap: 12rpx;
  background: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.listItem:active {
  background: rgba(92, 155, 214, 0.08);
}

.listItemIcon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: rgba(92, 155, 214, 0.12);
  flex-shrink: 0;
}

.listItemContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.listItemTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.listItemSub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.listItemArrow {
  font-size: 28rpx;
  color: var(--color-text-light);
  flex-shrink: 0;
}

/* ==================== 空状态样式 ==================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: linear-gradient(180deg, rgba(227, 242, 253, 0.5), rgba(255, 224, 178, 0.3));
  border-radius: var(--radius-xl);
}

.emptyIcon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
  animation: float 3s ease-in-out infinite;
}

.emptyText {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* ==================== 加载状态 ==================== */
.loadingWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loadingText {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: 16rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

/* ==================== 工具类 ==================== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }
.gap-xl { gap: var(--spacing-xl); }
.gap-2xl { gap: var(--spacing-2xl); }

/* ==================== 背景渐变 ==================== */
.bg-gradient-blue {
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.08), rgba(107, 163, 220, 0.04));
}

.bg-gradient-yellow {
  background: linear-gradient(135deg, rgba(255, 224, 130, 0.12), rgba(255, 208, 79, 0.06));
}

.bg-gradient-pink {
  background: linear-gradient(135deg, rgba(244, 143, 177, 0.12), rgba(236, 64, 122, 0.06));
}

.bg-gradient-mint {
  background: linear-gradient(135deg, rgba(128, 222, 234, 0.12), rgba(77, 208, 225, 0.06));
}

/* ==================== 动画 ==================== */
@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
