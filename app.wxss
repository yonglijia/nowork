/**
 * 全局设计规范
 * 风格：温暖、治愈、轻幽默、不焦虑、不鸡血
 * 特点：简约、干净、柔和、圆角、透气、清晰
 */

/* ==================== 设计变量 ==================== */
/* 色彩规范 */
/* 主色：温柔蓝 #E3F2FD */
/* 辅助色：浅粉 #FCE4EC、浅黄 #FFF8E1、浅灰 #F5F5F5 */

/* ==================== 全局基础 ==================== */
page {
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  background: #F5F8FA;
  color: #2C3E50;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 页面容器 - 不加padding，让各区块自己控制 */
.safePage {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* ==================== 卡片样式 ==================== */
.cardSurface {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(44, 62, 80, 0.06);
}

/* 药丸形状 */
.pill {
  border-radius: 999rpx;
}

/* 按钮清除默认样式 */
.btnClean::after {
  border: none;
}

/* ==================== 主按钮样式 ==================== */
/* 主按钮：温柔蓝色 */
.btnPrimary {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(92, 155, 214, 0.25);
  border: none;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 次要按钮：幽灵样式 */
.btnGhost {
  background: #ffffff;
  border: 2rpx solid rgba(92, 155, 214, 0.25);
  color: #5C9BD6;
  font-weight: 600;
  border-radius: 20rpx;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 文字按钮 */
.btnText {
  background: transparent;
  color: #5C9BD6;
  font-weight: 500;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  border: none;
}

/* ==================== 文字样式 ==================== */
/* 大标题 */
.titleLarge {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: 0.5rpx;
}

/* 标题 */
.titleMedium {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E50;
}

/* 小标题 */
.titleSmall {
  font-size: 30rpx;
  font-weight: 600;
  color: #34495E;
}

/* 正文 */
.bodyText {
  font-size: 28rpx;
  color: #5D6D7E;
  line-height: 1.6;
}

/* 辅助文字 */
.hintText {
  font-size: 24rpx;
  color: #85929E;
}

/* ==================== 标签样式 ==================== */
.tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(92, 155, 214, 0.1);
  border: 2rpx solid rgba(92, 155, 214, 0.2);
  color: #5C9BD6;
  font-size: 24rpx;
  font-weight: 500;
}

.tag.active {
  background: #5C9BD6;
  border-color: #5C9BD6;
  color: #ffffff;
}

/* 粉色标签 */
.tagPink {
  background: rgba(252, 228, 236, 0.8);
  border-color: rgba(236, 178, 196, 0.3);
  color: #C06172;
}

/* 黄色标签 */
.tagYellow {
  background: rgba(255, 248, 225, 0.9);
  border-color: rgba(255, 213, 79, 0.3);
  color: #9A7B4F;
}

/* 蓝色标签 */
.tagBlue {
  background: rgba(227, 242, 253, 0.9);
  border-color: rgba(144, 202, 249, 0.3);
  color: #4A7BA7;
}

/* ==================== 输入框样式 ==================== */
.inputField {
  width: 100%;
  height: 96rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  color: #2C3E50;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.inputField:focus {
  border-color: rgba(92, 155, 214, 0.4);
  background: #ffffff;
}

.inputField::placeholder {
  color: #9AA5B1;
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: rgba(92, 155, 214, 0.12);
  margin: 16rpx 0;
}

/* ==================== 弹窗样式 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  flex-shrink: 0;
}

.modalTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  text-align: center;
}

.modalDesc {
  font-size: 26rpx;
  color: #5D6D7E;
  text-align: center;
  line-height: 1.5;
}

.modalActions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.modalBtn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
  border: none;
}

.modalBtn.cancel {
  background: #F8FAFC;
  color: #5D6D7E;
}

.modalBtn.confirm {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
}

.modalBtn.danger {
  background: rgba(235, 160, 160, 0.15);
  color: #B87070;
}

/* ==================== 列表项样式 ==================== */
.listItem {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.listItemIcon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: rgba(92, 155, 214, 0.1);
}

.listItemContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.listItemTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.listItemSub {
  font-size: 24rpx;
  color: #85929E;
}

.listItemArrow {
  font-size: 32rpx;
  color: #9AA5B1;
}

/* ==================== 空状态样式 ==================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.emptyIcon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.emptyText {
  font-size: 28rpx;
  color: #85929E;
  text-align: center;
  line-height: 1.6;
}

/* ==================== 加载状态 ==================== */
.loadingWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loadingText {
  font-size: 26rpx;
  color: #85929E;
  margin-top: 16rpx;
}

/* ==================== 渐变背景 ==================== */
/* 温柔蓝渐变 */
.bgBlue {
  background: linear-gradient(135deg, #E3F2FD 0%, #F0F7FF 100%);
}

/* 浅粉渐变 */
.bgPink {
  background: linear-gradient(135deg, #FCE4EC 0%, #FFF0F5 100%);
}

/* 浅黄渐变 */
.bgYellow {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 100%);
}

/* ==================== 卡片特殊样式 ==================== */
/* 强调卡片 - 用于重点内容 */
.cardHighlight {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(92, 155, 214, 0.25);
}

/* 柔和卡片 */
.cardSoft {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
}

/* ==================== 工具类 ==================== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }
.gap-24 { gap: 24rpx; }
