page {
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
    Arial, "Noto Sans", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
    sans-serif;
  background: #ecfdf5;
  color: #0f172a;
}

.safePage {
  padding: 32rpx;
}

.cardSurface {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(45, 212, 191, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.pill {
  border-radius: 999rpx;
}

.btnClean::after {
  border: none;
}

.btnMintPrimary {
  background: linear-gradient(135deg, #2dd4bf, #34d399);
  color: #ffffff;
  font-weight: 900;
  letter-spacing: 1rpx;
  box-shadow: 0 14rpx 28rpx rgba(45, 212, 191, 0.28);
}

.btnMintGhost {
  background: rgba(255, 255, 255, 0.85);
  border: 2rpx solid rgba(45, 212, 191, 0.22);
  color: #115e59;
  font-weight: 800;
  box-shadow: 0 10rpx 20rpx rgba(17, 94, 89, 0.06);
}

