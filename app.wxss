/**
 * 全局设计规范
 * 风格：温暖、治愈、轻幽默、不焦虑、不鸡血
 * 特点：简约、干净、柔和、圆角、透气、低饱和度
 */

/* ==================== 设计变量 ==================== */
/* 色彩规范 */
/* 主色：温柔蓝 #E3F2FD / 治愈青 #E0F2F1 */
/* 辅助色：浅粉 #FCE4EC、浅黄 #FFF8E1、浅灰 #F5F5F5 */

/* ==================== 全局基础 ==================== */
page {
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  background: #F8FBFB;
  color: #3D5A5C;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 安全区域页面 */
.safePage {
  padding: 32rpx;
  box-sizing: border-box;
}

/* ==================== 卡片样式 ==================== */
.cardSurface {
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.06);
}

/* 药丸形状 */
.pill {
  border-radius: 999rpx;
}

/* 按钮清除默认样式 */
.btnClean::after {
  border: none;
}

/* ==================== 主按钮样式 ==================== */
/* 主按钮：温柔青色 */
.btnPrimary {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(126, 189, 184, 0.25);
  border: none;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 次要按钮：幽灵样式 */
.btnGhost {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(126, 189, 184, 0.3);
  color: #5A8A8D;
  font-weight: 600;
  border-radius: 20rpx;
  box-shadow: none;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 文字按钮 */
.btnText {
  background: transparent;
  color: #7EBDB8;
  font-weight: 500;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  border: none;
}

/* ==================== 文字样式 ==================== */
/* 大标题 */
.titleLarge {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
  letter-spacing: 0.5rpx;
}

/* 标题 */
.titleMedium {
  font-size: 34rpx;
  font-weight: 600;
  color: #3D5A5C;
}

/* 小标题 */
.titleSmall {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A6B6E;
}

/* 正文 */
.bodyText {
  font-size: 28rpx;
  color: #5A7A7D;
  line-height: 1.6;
}

/* 辅助文字 */
.hintText {
  font-size: 24rpx;
  color: #8AA0A2;
}

/* ==================== 标签样式 ==================== */
.tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(126, 189, 184, 0.1);
  border: 2rpx solid rgba(126, 189, 184, 0.2);
  color: #5A8A8D;
  font-size: 24rpx;
  font-weight: 500;
}

.tag.active {
  background: #7EBDB8;
  border-color: #7EBDB8;
  color: #ffffff;
}

/* 粉色标签 */
.tagPink {
  background: rgba(252, 228, 236, 0.6);
  border-color: rgba(236, 178, 196, 0.3);
  color: #B87A8C;
}

/* 黄色标签 */
.tagYellow {
  background: rgba(255, 248, 225, 0.8);
  border-color: rgba(255, 213, 79, 0.3);
  color: #A69050;
}

/* 蓝色标签 */
.tagBlue {
  background: rgba(227, 242, 253, 0.8);
  border-color: rgba(144, 202, 249, 0.3);
  color: #5A8AB5;
}

/* ==================== 输入框样式 ==================== */
.inputField {
  width: 100%;
  height: 96rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  background: rgba(126, 189, 184, 0.06);
  border-radius: 20rpx;
  color: #3D5A5C;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.inputField:focus {
  border-color: rgba(126, 189, 184, 0.3);
  background: rgba(255, 255, 255, 0.95);
}

.inputField::placeholder {
  color: #A0B5B7;
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: rgba(126, 189, 184, 0.15);
  margin: 16rpx 0;
}

/* ==================== 弹窗样式 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 90, 92, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  flex-shrink: 0;
}

.modalTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
  text-align: center;
}

.modalDesc {
  font-size: 26rpx;
  color: #7A9A9D;
  text-align: center;
  line-height: 1.5;
}

.modalActions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.modalBtn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
  border: none;
}

.modalBtn.cancel {
  background: rgba(126, 189, 184, 0.1);
  color: #5A8A8D;
}

.modalBtn.confirm {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
}

.modalBtn.danger {
  background: rgba(235, 160, 160, 0.15);
  color: #C87070;
}

/* ==================== 列表项样式 ==================== */
.listItem {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
}

.listItemIcon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: rgba(126, 189, 184, 0.12);
}

.listItemContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.listItemTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.listItemSub {
  font-size: 24rpx;
  color: #8AA0A2;
}

.listItemArrow {
  font-size: 32rpx;
  color: #A0B5B7;
}

/* ==================== 空状态样式 ==================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.emptyIcon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
  text-align: center;
  line-height: 1.6;
}

/* ==================== 加载状态 ==================== */
.loadingWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loadingText {
  font-size: 26rpx;
  color: #8AA0A2;
  margin-top: 16rpx;
}

/* ==================== 渐变背景 ==================== */
/* 温柔蓝渐变 */
.bgBlue {
  background: linear-gradient(135deg, #E3F2FD 0%, #F0F7FF 100%);
}

/* 治愈青渐变 */
.bgMint {
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
}

/* 浅粉渐变 */
.bgPink {
  background: linear-gradient(135deg, #FCE4EC 0%, #FFF0F5 100%);
}

/* 浅黄渐变 */
.bgYellow {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 100%);
}

/* ==================== 卡片特殊样式 ==================== */
/* 强调卡片 - 用于重点内容 */
.cardHighlight {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.3);
}

/* 柔和卡片 */
.cardSoft {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(126, 189, 184, 0.1);
}

/* ==================== 工具类 ==================== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.gap-8 { gap: 8rpx; }
.gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }
.gap-24 { gap: 24rpx; }

.p-16 { padding: 16rpx; }
.p-20 { padding: 20rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }

.mb-8 { margin-bottom: 8rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-24 { margin-bottom: 24rpx; }
