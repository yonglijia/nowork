/**
 * 指南页面样式 - 小清新版本
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: linear-gradient(180deg, #F9FBFA 0%, #FCFEF7 50%, #F9FBFA 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.7) 0%, rgba(254, 248, 243, 0.8) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.5rpx;
}

.sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  gap: 10rpx;
  border: 1.5rpx solid rgba(184, 230, 219, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(184, 230, 219, 0.06);
  transition: all 0.2s ease;
}

.searchBar:active {
  border-color: #B8E6DB;
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.12);
  background: rgba(248, 250, 252, 0.5);
}

.searchIcon {
  font-size: 26rpx;
  color: #9CA3AF;
}

.searchInput {
  flex: 1;
  font-size: 26rpx;
  color: #3D3D3D;
  background: transparent;
  font-weight: 500;
}

.searchInput::placeholder {
  color: #B8C5D6;
}

.clearBtn {
  font-size: 26rpx;
  color: #B8C5D6;
  padding: 0 4rpx;
  transition: color 0.2s ease;
}

.clearBtn:active {
  color: #6B7280;
}

/* ==================== 分类导航 ==================== */
.categoryBar {
  white-space: nowrap;
}

.categoryScroll {
  display: inline-flex;
  gap: 8rpx;
}

.categoryItem {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #6B7280;
  background: #FFFFFF;
  border: 1.5rpx solid rgba(184, 230, 219, 0.15);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.categoryItem:active {
  transform: scale(0.92);
}

.categoryItem.active {
  background: linear-gradient(135deg, #B8E6DB, #A0D9CF);
  border-color: transparent;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.25);
}

/* ==================== 内容列表 ==================== */
.contentList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.contentItem {
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
  transition: all 0.2s ease;
}

.contentItem:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 4rpx 12rpx rgba(61, 61, 61, 0.06);
}

.contentHeader {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.contentIcon {
  font-size: 30rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.1), rgba(184, 230, 219, 0.05));
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contentInfo {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.contentTitle {
  font-size: 27rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.2rpx;
}

.contentSummary {
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.4;
}

.contentActions {
  display: flex;
  gap: 14rpx;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(184, 230, 219, 0.08);
}

.actionBtn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  transition: all 0.2s ease;
}

.actionBtn:active {
  opacity: 0.6;
  transform: scale(0.93);
}

.actionIcon {
  font-size: 20rpx;
}

.actionText {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 600;
}

/* ==================== 空状态 ==================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.emptyIcon {
  font-size: 72rpx;
  margin-bottom: 14rpx;
  opacity: 0.2;
  animation: floatGentle 4s ease-in-out infinite;
}

.emptyText {
  font-size: 26rpx;
  color: #9CA3AF;
}
