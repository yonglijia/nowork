/**
 * 指南页面样式 - 设计感升级版
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(180deg, #F5F8FA 0%, #F9FBFC 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.9) 0%, rgba(245, 249, 255, 0.95) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.5rpx;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #85929E;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
  gap: 10rpx;
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(92, 155, 214, 0.06);
  transition: all 0.2s ease;
}

.searchBar:active {
  border-color: #5C9BD6;
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.12);
}

.searchIcon {
  font-size: 26rpx;
  color: #85929E;
}

.searchInput {
  flex: 1;
  font-size: 26rpx;
  color: #2C3E50;
  background: transparent;
}

.searchInput::placeholder {
  color: #9AA5B1;
}

.clearBtn {
  font-size: 28rpx;
  color: #9AA5B1;
  padding: 0 6rpx;
  transition: color 0.2s ease;
}

.clearBtn:active {
  color: #5D6D7E;
}

/* ==================== 分类导航 ==================== */
.categoryBar {
  white-space: nowrap;
}

.categoryScroll {
  display: inline-flex;
  gap: 10rpx;
}

.categoryItem {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5D6D7E;
  background: #ffffff;
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.categoryItem:active {
  transform: scale(0.96);
}

.categoryItem.active {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.25);
}

/* ==================== 内容列表 ==================== */
.contentList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.contentItem {
  padding: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
  transition: all 0.2s ease;
}

.contentItem:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 80, 0.08);
}

.contentHeader {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.contentIcon {
  font-size: 32rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.1), rgba(92, 155, 214, 0.05));
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contentInfo {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contentTitle {
  font-size: 27rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.3rpx;
}

.contentSummary {
  font-size: 24rpx;
  color: #85929E;
  line-height: 1.4;
}

.contentActions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(92, 155, 214, 0.08);
}

.actionBtn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  transition: all 0.2s ease;
}

.actionBtn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.actionIcon {
  font-size: 22rpx;
}

.actionText {
  font-size: 22rpx;
  color: #85929E;
  font-weight: 500;
}

/* ==================== 空状态 ==================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.emptyIcon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.3;
  animation: float 3s ease-in-out infinite;
}

.emptyText {
  font-size: 26rpx;
  color: #85929E;
}
