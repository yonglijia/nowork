/**
 * 指南页面样式
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5D6D7E;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  gap: 10rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
}

.searchIcon {
  font-size: 26rpx;
}

.searchInput {
  flex: 1;
  font-size: 26rpx;
  color: #2C3E50;
}

.searchInput::placeholder {
  color: #9AA5B1;
}

.clearBtn {
  font-size: 28rpx;
  color: #9AA5B1;
  padding: 0 8rpx;
}

/* ==================== 分类导航 ==================== */
.categoryBar {
  white-space: nowrap;
}

.categoryScroll {
  display: inline-flex;
  gap: 12rpx;
}

.categoryItem {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #5D6D7E;
  background: #ffffff;
  border: 1rpx solid rgba(92, 155, 214, 0.12);
}

.categoryItem.active {
  background: #5C9BD6;
  border-color: #5C9BD6;
  color: #ffffff;
}

/* ==================== 内容列表 ==================== */
.contentList {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.contentItem {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.contentHeader {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.contentIcon {
  font-size: 36rpx;
  width: 52rpx;
  height: 52rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contentInfo {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contentTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.contentSummary {
  font-size: 24rpx;
  color: #85929E;
  line-height: 1.4;
}

.contentActions {
  display: flex;
  gap: 20rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(92, 155, 214, 0.08);
}

.actionBtn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.actionIcon {
  font-size: 24rpx;
}

.actionText {
  font-size: 22rpx;
  color: #85929E;
}

/* ==================== 空状态 ==================== */
.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.emptyIcon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.emptyText {
  font-size: 26rpx;
  color: #85929E;
}
