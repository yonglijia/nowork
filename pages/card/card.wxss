.page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 900;
  color: #064e3b;
}

.badge {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  background: rgba(45, 212, 191, 0.16);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.22);
}

.wrap {
  padding: 24rpx;
}

.card {
  background: radial-gradient(900rpx 360rpx at 10% 0%, rgba(153, 246, 228, 0.28), rgba(255,255,255,0) 55%),
    radial-gradient(900rpx 360rpx at 100% 40%, rgba(45, 212, 191, 0.28), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, #0f766e, #115e59);
  border-radius: 26rpx;
  padding: 22rpx;
  color: rgba(255, 255, 255, 0.98);
}

.memeBox {
  height: 380rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.memeImg {
  width: 100%;
  height: 100%;
}

.memeEmoji {
  font-size: 160rpx;
}

.cardText {
  display: block;
  margin-top: 22rpx;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.28;
}

.cardFooter {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

.hint {
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  border: 2rpx dashed rgba(45, 212, 191, 0.26);
  background: rgba(255, 255, 255, 0.6);
}

.hintText {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
}

