/**
 * 拒绝文案卡片页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ==================== 顶部栏 ==================== */
.topBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
}

.badge {
  padding: 8rpx 14rpx;
  font-size: 20rpx;
  background: rgba(92, 155, 214, 0.1);
  color: #5C9BD6;
  border-radius: 999rpx;
  border: none;
}

/* ==================== 卡片容器 ==================== */
.wrap {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(44, 62, 80, 0.05);
}

.card {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  border-radius: 20rpx;
  padding: 24rpx;
  color: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(92, 155, 214, 0.25);
}

.memeBox {
  height: 340rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.memeImg {
  width: 100%;
  height: 100%;
}

.memeEmoji {
  font-size: 120rpx;
}

.cardText {
  display: block;
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.cardFooter {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  opacity: 0.85;
}

/* ==================== 提示 ==================== */
.hint {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(92, 155, 214, 0.2);
  background: #ffffff;
}

.hintText {
  font-size: 22rpx;
  color: #5D6D7E;
}
