/**
 * 拒绝文案卡片页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: #F8FBFB;
}

/* ==================== 顶部栏 ==================== */
.topBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.badge {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  background: rgba(126, 189, 184, 0.12);
  color: #5A8A8D;
  border-radius: 999rpx;
  border: none;
}

/* ==================== 卡片容器 ==================== */
.wrap {
  padding: 24rpx;
}

.card {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  border-radius: 24rpx;
  padding: 24rpx;
  color: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.25);
}

.memeBox {
  height: 380rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.memeImg {
  width: 100%;
  height: 100%;
}

.memeEmoji {
  font-size: 140rpx;
}

.cardText {
  display: block;
  margin-top: 22rpx;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.4;
}

.cardFooter {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

/* ==================== 提示 ==================== */
.hint {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(126, 189, 184, 0.25);
  background: rgba(255, 255, 255, 0.8);
  margin: 0 24rpx;
}

.hintText {
  font-size: 24rpx;
  color: #7A9A9D;
}
