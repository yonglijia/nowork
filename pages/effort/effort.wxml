<view class="safePage page">
  <view class="top cardSurface">
    <view class="topRow">
      <view class="titleWrap">
        <text class="title">今日实干</text>
        <text class="sub">把付出记下来，别让努力悄悄消失</text>
      </view>
      <view class="statPill pill">
        <text class="statText">{{doneCount}}/{{totalCount}} 已完成</text>
      </view>
    </view>

    <view class="miniStats">
      <view class="mini">
        <text class="miniLabel">工作</text>
        <text class="miniValue">{{form.workHours}}h</text>
      </view>
      <view class="mini">
        <text class="miniLabel">加班</text>
        <text class="miniValue">{{form.overtimeHours}}h</text>
      </view>
      <view class="mini">
        <text class="miniLabel">任务</text>
        <text class="miniValue">{{form.tasksDone}}项</text>
      </view>
    </view>
  </view>

  <!-- 紧凑表单 -->
  <view class="form cardSurface">
    <text class="formTitle">点选记录</text>
    
    <!-- 第一行：工作时长 + 加班时长 -->
    <view class="formRow">
      <view class="formItem">
        <text class="formLabel">工作</text>
        <picker mode="selector" range="{{workHoursOptions}}" value="{{workHoursIndex}}" bindchange="onWorkHoursChange">
          <view class="formPicker">{{form.workHours}}h</view>
        </picker>
      </view>
      <view class="formItem">
        <text class="formLabel">加班</text>
        <input class="formInput" type="number" value="{{form.overtimeHours}}" maxlength="2" bindinput="onOvertimeInput" placeholder="0h" />
      </view>
      <view class="formItem">
        <text class="formLabel">任务</text>
        <picker mode="selector" range="{{taskCountOptions}}" value="{{taskIndex}}" bindchange="onTaskChange">
          <view class="formPicker">{{form.tasksDone}}项</view>
        </picker>
      </view>
    </view>
    
    <!-- 第二行：额外付出标签 -->
    <view class="extraRow">
      <text class="formLabel">额外付出</text>
      <view class="chips">
        <view
          wx:for="{{extraOptions}}"
          wx:key="*this"
          class="chip {{form.extras.includes(item) ? 'active' : ''}}"
          bindtap="toggleExtra"
          data-item="{{item}}"
        >{{item}}</view>
      </view>
    </view>

    <button class="submit" bindtap="onSubmit">生成实干卡片</button>
  </view>

  <view wx:if="{{card}}" class="cardWrap cardSurface">
    <view class="card">
      <view class="cardHead">
        <text class="cardTitle">今日实干卡片</text>
        <text class="cardDate">{{card.dateText}}</text>
      </view>
      <view class="rows">
        <view class="r">
          <text class="k">工作时长</text><text class="v">{{card.workHours}}h</text>
        </view>
        <view class="r">
          <text class="k">加班时长</text><text class="v">{{card.overtimeHours}}h</text>
        </view>
        <view class="r">
          <text class="k">完成任务</text><text class="v">{{card.tasksDone}}项</text>
        </view>
        <view class="r">
          <text class="k">额外付出</text><text class="v">{{card.extrasText}}</text>
        </view>
      </view>

      <view class="medals" wx:if="{{unlockedMedals.length}}">
        <text class="medalTitle">新解锁</text>
        <view class="medalRow">
          <view wx:for="{{unlockedMedals}}" wx:key="key" class="medal pill">{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="actions">
      <button class="actionBtn btnMintGhost btnClean" bindtap="onSaveImage">保存</button>
      <button class="actionBtn btnMintPrimary btnClean" open-type="share">公开分享</button>
      <button class="actionBtn btnMintGhost btnClean" bindtap="onPrivateShare">私密</button>
    </view>
  </view>

  <view class="calendar cardSurface">
    <view class="calTop">
      <text class="sectionTitle">历史日历</text>
      <text class="calHint">点日期查看</text>
    </view>
    <view class="weekRow">
      <text wx:for="{{weekLabels}}" wx:key="*this" class="week">{{item}}</text>
    </view>
    <view class="grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="key"
        class="day {{item.isToday ? 'today' : ''}} {{item.hasData ? 'has' : ''}} {{selectedDateKey===item.dateKey ? 'sel' : ''}}"
        bindtap="onDayTap"
        data-datekey="{{item.dateKey}}"
      >
        <text class="d">{{item.label}}</text>
        <view wx:if="{{item.hasData}}" class="dot"></view>
      </view>
    </view>
  </view>

  <view class="entryRow">
    <view class="entry cardSurface" bindtap="goReport">
      <view class="entryText">
        <text class="entryTitle">周/月报告</text>
        <text class="entrySub">自动统计你的实干数据</text>
      </view>
      <text class="entryArrow">›</text>
    </view>
    <view class="entry cardSurface" bindtap="goMedals">
      <view class="entryText">
        <text class="entryTitle">勋章墙</text>
        <text class="entrySub">看看你解锁了哪些称号</text>
      </view>
      <text class="entryArrow">›</text>
    </view>
  </view>

  <canvas type="2d" id="effortCanvas" class="hiddenCanvas"></canvas>
</view>
