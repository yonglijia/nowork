/**
 * 今日实干页面样式 - 设计感升级版
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(180deg, #F5F8FA 0%, #F9FBFC 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.top {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.9) 0%, rgba(245, 249, 255, 0.95) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.08);
}

.topRow {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.titleWrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.5rpx;
}

.sub {
  font-size: 24rpx;
  color: #85929E;
}

.statPill {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.12), rgba(92, 155, 214, 0.08));
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(92, 155, 214, 0.2);
  box-shadow: 0 2rpx 8rpx rgba(92, 155, 214, 0.1);
}

.statText {
  font-size: 22rpx;
  font-weight: 600;
  color: #5C9BD6;
}

/* ==================== 迷你统计 ==================== */
.miniStats {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
}

.mini {
  border-radius: 12rpx;
  padding: 14rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(227, 242, 253, 0.3));
  border: 1.5rpx solid rgba(92, 155, 214, 0.12);
  transition: all 0.2s ease;
}

.mini:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, rgba(255, 255, 255, 1), rgba(227, 242, 253, 0.5));
}

.miniLabel {
  font-size: 20rpx;
  color: #85929E;
  font-weight: 500;
}

.miniValue {
  display: block;
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #5C9BD6;
  letter-spacing: -0.5rpx;
}

/* ==================== 表单区域 ==================== */
.form {
  padding: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.formTitle {
  font-size: 26rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 12rpx;
  letter-spacing: -0.3rpx;
}

.formRow {
  display: flex;
  gap: 10rpx;
}

.formItem {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.formLabel {
  font-size: 20rpx;
  color: #85929E;
  font-weight: 600;
}

.formPicker {
  padding: 12rpx;
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.08), rgba(92, 155, 214, 0.04));
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  border-radius: 10rpx;
  color: #34495E;
  font-weight: 700;
  font-size: 26rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.formPicker:active {
  background: rgba(92, 155, 214, 0.12);
  border-color: #5C9BD6;
}

.formInput {
  padding: 12rpx;
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.08), rgba(92, 155, 214, 0.04));
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  border-radius: 10rpx;
  color: #34495E;
  font-weight: 700;
  font-size: 26rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.formInput:focus {
  background: rgba(92, 155, 214, 0.12);
  border-color: #5C9BD6;
}

.extraRow {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* ==================== 标签选择 ==================== */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.chip {
  padding: 10rpx 14rpx;
  background: #ffffff;
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  border-radius: 999rpx;
  color: #5D6D7E;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.chip:active {
  transform: scale(0.95);
}

.chip.active {
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.2), rgba(92, 155, 214, 0.1));
  border-color: #5C9BD6;
  color: #5C9BD6;
  box-shadow: 0 2rpx 8rpx rgba(92, 155, 214, 0.15);
}

/* ==================== 提交按钮 ==================== */
.submit {
  margin-top: 14rpx;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  font-weight: 700;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(92, 155, 214, 0.2);
  border: none;
  transition: all 0.2s ease;
  letter-spacing: -0.3rpx;
}

.submit:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(92, 155, 214, 0.15);
}

/* ==================== 今日卡片 ==================== */
.cardWrap {
  padding: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.card {
  border-radius: 16rpx;
  padding: 16rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  box-shadow: 0 4rpx 16rpx rgba(92, 155, 214, 0.2);
}

.cardHead {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.cardTitle {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: -0.3rpx;
}

.cardDate {
  font-size: 20rpx;
  opacity: 0.85;
}

.rows {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.r {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.k {
  font-size: 22rpx;
  opacity: 0.9;
  font-weight: 600;
}

.v {
  font-size: 24rpx;
  font-weight: 700;
}

/* ==================== 勋章区域 ==================== */
.medals {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.medalTitle {
  font-size: 22rpx;
  opacity: 0.9;
  font-weight: 700;
}

.medalRow {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.medal {
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

/* ==================== 操作按钮 ==================== */
.actions {
  margin-top: 12rpx;
  display: flex;
  align-items: stretch;
  gap: 10rpx;
}

.actionBtn {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #5C9BD6;
  font-weight: 700;
  font-size: 24rpx;
  border: 2rpx solid rgba(92, 155, 214, 0.2);
  transition: all 0.2s ease;
  letter-spacing: -0.2rpx;
}

.actionBtn:active {
  transform: scale(0.96);
  background: rgba(92, 155, 214, 0.05);
}

/* ==================== 日历区域 ==================== */
.calendar {
  padding: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.calTop {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.sectionTitle {
  font-size: 26rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.3rpx;
}

.calHint {
  font-size: 20rpx;
  color: #85929E;
  font-weight: 500;
}

.weekRow {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.week {
  text-align: center;
  font-size: 20rpx;
  color: #9AA5B1;
  font-weight: 600;
}

.grid {
  margin-top: 6rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.day {
  height: 56rpx;
  border-radius: 10rpx;
  background: #F8FAFC;
  border: 1rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  color: #85929E;
  transition: all 0.2s ease;
}

.day:active {
  transform: scale(0.95);
}

.day.today {
  border-color: rgba(92, 155, 214, 0.3);
  background: rgba(227, 242, 253, 0.3);
}

.day.has {
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.6), rgba(227, 242, 253, 0.3));
  border-color: rgba(92, 155, 214, 0.2);
}

.day.sel {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(92, 155, 214, 0.2);
}

.d {
  font-size: 22rpx;
  font-weight: 700;
}

.dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #5C9BD6;
}

.day.sel .dot {
  background: #ffffff;
}

/* ==================== 入口列表 ==================== */
.entryRow {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.entry {
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
  transition: all 0.2s ease;
}

.entry:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 80, 0.08);
}

.entryText {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.3rpx;
}

.entrySub {
  font-size: 22rpx;
  color: #85929E;
}

.entryArrow {
  font-size: 28rpx;
  color: #9AA5B1;
  transition: transform 0.2s ease;
}

.entry:active .entryArrow {
  transform: translateX(4rpx);
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}
