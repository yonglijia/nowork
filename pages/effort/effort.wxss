/**
 * 今日实干页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 170rpx;
  background: #F8FBFB;
}

/* ==================== 顶部区域 ==================== */
.top {
  padding: 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.topRow {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.titleWrap {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.sub {
  font-size: 24rpx;
  color: #8AA0A2;
}

.statPill {
  padding: 10rpx 18rpx;
  background: rgba(126, 189, 184, 0.12);
  border-radius: 999rpx;
  border: none;
}

.statText {
  font-size: 22rpx;
  font-weight: 600;
  color: #5A8A8D;
}

/* ==================== 迷你统计 ==================== */
.miniStats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
}

.mini {
  border-radius: 20rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(126, 189, 184, 0.1);
}

.miniLabel {
  font-size: 22rpx;
  color: #8AA0A2;
  font-weight: 500;
}

.miniValue {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #7EBDB8;
}

/* ==================== 表单区域 ==================== */
.form {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.field {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  font-size: 24rpx;
  color: #7A9A9D;
  font-weight: 500;
}

.picker {
  padding: 20rpx;
  background: rgba(126, 189, 184, 0.06);
  border: 1rpx solid rgba(126, 189, 184, 0.15);
  border-radius: 16rpx;
  color: #4A6B6E;
  font-weight: 500;
}

.inline {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input {
  width: 220rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(126, 189, 184, 0.15);
  border-radius: 16rpx;
  color: #4A6B6E;
  font-weight: 500;
}

.unit {
  font-size: 22rpx;
  color: #8AA0A2;
  font-weight: 500;
}

/* ==================== 标签选择 ==================== */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(126, 189, 184, 0.15);
  border-radius: 999rpx;
  color: #5A8A8D;
  font-size: 24rpx;
  font-weight: 500;
}

.chip.active {
  background: rgba(126, 189, 184, 0.15);
  border-color: rgba(126, 189, 184, 0.25);
  color: #5A8A8D;
}

/* ==================== 提交按钮 ==================== */
.submit {
  margin-top: 22rpx;
  height: 92rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  font-weight: 600;
  font-size: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(126, 189, 184, 0.25);
}

/* ==================== 今日卡片 ==================== */
.cardWrap {
  padding: 24rpx;
  margin: 0 24rpx;
}

.card {
  border-radius: 24rpx;
  padding: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.25);
}

.cardHead {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 14rpx;
}

.cardTitle {
  font-size: 32rpx;
  font-weight: 600;
}

.cardDate {
  font-size: 22rpx;
  opacity: 0.8;
}

.rows {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.r {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
}

.k {
  font-size: 24rpx;
  opacity: 0.9;
  font-weight: 500;
}

.v {
  font-size: 26rpx;
  font-weight: 600;
}

/* ==================== 勋章区域 ==================== */
.medals {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.medalTitle {
  font-size: 24rpx;
  opacity: 0.9;
  font-weight: 600;
}

.medalRow {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.medal {
  padding: 10rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* ==================== 操作按钮 ==================== */
.actions {
  margin-top: 18rpx;
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.actionBtn {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  color: #5A8A8D;
  font-weight: 500;
  border: 1rpx solid rgba(126, 189, 184, 0.15);
}

/* ==================== 日历区域 ==================== */
.calendar {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.calTop {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.calHint {
  font-size: 22rpx;
  color: #8AA0A2;
  font-weight: 500;
}

.weekRow {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.week {
  text-align: center;
  font-size: 22rpx;
  color: #A0B5B7;
  font-weight: 500;
}

.grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.day {
  height: 86rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(126, 189, 184, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #8AA0A2;
}

.day.today {
  border-color: rgba(126, 189, 184, 0.3);
}

.day.has {
  background: rgba(126, 189, 184, 0.08);
  border-color: rgba(126, 189, 184, 0.2);
}

.day.sel {
  background: rgba(126, 189, 184, 0.15);
  border-color: rgba(126, 189, 184, 0.3);
  color: #5A8A8D;
}

.d {
  font-size: 24rpx;
  font-weight: 600;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #7EBDB8;
}

/* ==================== 入口列表 ==================== */
.entryRow {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.entry {
  padding: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.entryText {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.entryTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.entrySub {
  font-size: 22rpx;
  color: #8AA0A2;
}

.entryArrow {
  font-size: 40rpx;
  color: #A0B5B7;
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}
