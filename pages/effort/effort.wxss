/**
 * 今日实干页面样式 - 小清新版本
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: linear-gradient(180deg, #F9FBFA 0%, #FCFEF7 50%, #F9FBFA 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.top {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.7) 0%, rgba(254, 248, 243, 0.8) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.08);
}

.topRow {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.titleWrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.5rpx;
}

.sub {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.statPill {
  padding: 8rpx 14rpx;
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.1), rgba(184, 230, 219, 0.05));
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(184, 230, 219, 0.2);
  box-shadow: 0 2rpx 6rpx rgba(184, 230, 219, 0.08);
}

.statText {
  font-size: 22rpx;
  font-weight: 700;
  color: #7EC8B8;
}

/* ==================== 迷你统计 ==================== */
.miniStats {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
}

.mini {
  border-radius: 10rpx;
  padding: 12rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(232, 247, 243, 0.2));
  border: 1.5rpx solid rgba(184, 230, 219, 0.1);
  transition: all 0.2s ease;
}

.mini:active {
  transform: scale(0.94);
  background: linear-gradient(135deg, rgba(255, 255, 255, 1), rgba(232, 247, 243, 0.4));
}

.miniLabel {
  font-size: 20rpx;
  color: #9CA3AF;
  font-weight: 600;
}

.miniValue {
  display: block;
  margin-top: 4rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #7EC8B8;
  letter-spacing: -0.4rpx;
}

/* ==================== 表单区域 ==================== */
.form {
  padding: 14rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
}

.formTitle {
  font-size: 26rpx;
  font-weight: 800;
  color: #3D3D3D;
  margin-bottom: 10rpx;
  letter-spacing: -0.2rpx;
}

.formRow {
  display: flex;
  gap: 8rpx;
}

.formItem {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.formLabel {
  font-size: 20rpx;
  color: #9CA3AF;
  font-weight: 700;
}

.formPicker {
  padding: 10rpx;
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.08), rgba(184, 230, 219, 0.04));
  border: 1.5rpx solid rgba(184, 230, 219, 0.12);
  border-radius: 8rpx;
  color: #3D3D3D;
  font-weight: 700;
  font-size: 26rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.formPicker:active {
  background: rgba(184, 230, 219, 0.12);
  border-color: #B8E6DB;
}

.formInput {
  padding: 10rpx;
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.08), rgba(184, 230, 219, 0.04));
  border: 1.5rpx solid rgba(184, 230, 219, 0.12);
  border-radius: 8rpx;
  color: #3D3D3D;
  font-weight: 700;
  font-size: 26rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.formInput:focus {
  background: rgba(184, 230, 219, 0.12);
  border-color: #B8E6DB;
  box-shadow: 0 0 0 2rpx rgba(184, 230, 219, 0.1);
}

.extraRow {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* ==================== 标签选择 ==================== */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.chip {
  padding: 8rpx 12rpx;
  background: #FFFFFF;
  border: 1.5rpx solid rgba(184, 230, 219, 0.12);
  border-radius: 999rpx;
  color: #6B7280;
  font-size: 22rpx;
  font-weight: 700;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.chip:active {
  transform: scale(0.92);
}

.chip.active {
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.15), rgba(184, 230, 219, 0.08));
  border-color: #B8E6DB;
  color: #7EC8B8;
  box-shadow: 0 2rpx 8rpx rgba(184, 230, 219, 0.12);
}

/* ==================== 提交按钮 ==================== */
.submit {
  margin-top: 10rpx;
  height: 68rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #B8E6DB, #A0D9CF);
  color: #FFFFFF;
  font-weight: 800;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.2);
  border: none;
  transition: all 0.2s ease;
  letter-spacing: -0.2rpx;
}

.submit:active {
  transform: scale(0.94);
  box-shadow: 0 2rpx 6rpx rgba(184, 230, 219, 0.15);
}

/* ==================== 今日卡片 ==================== */
.cardWrap {
  padding: 14rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
}

.card {
  border-radius: 12rpx;
  padding: 14rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #B8E6DB, #A0D9CF);
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.2);
}

.cardHead {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10rpx;
}

.cardTitle {
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: -0.2rpx;
}

.cardDate {
  font-size: 20rpx;
  opacity: 0.85;
}

.rows {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.r {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.k {
  font-size: 22rpx;
  opacity: 0.9;
  font-weight: 700;
}

.v {
  font-size: 24rpx;
  font-weight: 800;
}

/* ==================== 勋章区域 ==================== */
.medals {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.medalTitle {
  font-size: 22rpx;
  opacity: 0.9;
  font-weight: 800;
}

.medalRow {
  margin-top: 4rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 5rpx;
}

.medal {
  padding: 5rpx 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* ==================== 操作按钮 ==================== */
.actions {
  margin-top: 10rpx;
  display: flex;
  align-items: stretch;
  gap: 8rpx;
}

.actionBtn {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  color: #7EC8B8;
  font-weight: 800;
  font-size: 24rpx;
  border: 1.5rpx solid rgba(184, 230, 219, 0.2);
  transition: all 0.2s ease;
  letter-spacing: -0.2rpx;
}

.actionBtn:active {
  transform: scale(0.92);
  background: rgba(232, 247, 243, 0.4);
}

/* ==================== 日历区域 ==================== */
.calendar {
  padding: 14rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
}

.calTop {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10rpx;
}

.sectionTitle {
  font-size: 26rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.2rpx;
}

.calHint {
  font-size: 20rpx;
  color: #9CA3AF;
  font-weight: 600;
}

.weekRow {
  margin-top: 8rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 3rpx;
}

.week {
  text-align: center;
  font-size: 20rpx;
  color: #B8C5D6;
  font-weight: 700;
}

.grid {
  margin-top: 4rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 3rpx;
}

.day {
  height: 52rpx;
  border-radius: 8rpx;
  background: #F9FBFA;
  border: 1rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rpx;
  color: #9CA3AF;
  transition: all 0.2s ease;
}

.day:active {
  transform: scale(0.92);
}

.day.today {
  border-color: rgba(184, 230, 219, 0.25);
  background: rgba(232, 247, 243, 0.3);
}

.day.has {
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.5), rgba(232, 247, 243, 0.2));
  border-color: rgba(184, 230, 219, 0.15);
}

.day.sel {
  background: linear-gradient(135deg, #B8E6DB, #A0D9CF);
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(184, 230, 219, 0.2);
}

.d {
  font-size: 22rpx;
  font-weight: 800;
}

.dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #7EC8B8;
}

.day.sel .dot {
  background: #FFFFFF;
}

/* ==================== 入口列表 ==================== */
.entryRow {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.entry {
  padding: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
  transition: all 0.2s ease;
}

.entry:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 4rpx 12rpx rgba(61, 61, 61, 0.06);
}

.entryText {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.2rpx;
}

.entrySub {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.entryArrow {
  font-size: 26rpx;
  color: #B8C5D6;
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.entry:active .entryArrow {
  transform: translateX(2rpx);
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}
