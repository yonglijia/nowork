.page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 900;
  color: #064e3b;
}

.badge {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  background: rgba(45, 212, 191, 0.16);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.22);
}

.wrap {
  padding: 24rpx;
}

.card {
  border-radius: 26rpx;
  padding: 22rpx;
  color: rgba(255, 255, 255, 0.98);
  background: radial-gradient(900rpx 360rpx at 10% 0%, rgba(153, 246, 228, 0.28), rgba(255,255,255,0) 55%),
    radial-gradient(900rpx 360rpx at 100% 40%, rgba(45, 212, 191, 0.28), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, #0f766e, #115e59);
}

.head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.cardTitle {
  font-size: 34rpx;
  font-weight: 900;
}

.date {
  font-size: 22rpx;
  opacity: 0.82;
}

.grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.cell {
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  padding: 18rpx 18rpx;
}

.k {
  font-size: 22rpx;
  opacity: 0.78;
  font-weight: 900;
}

.v {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.line {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lk {
  font-size: 22rpx;
  opacity: 0.78;
  font-weight: 900;
}

.lv {
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.28;
}

.footer {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  opacity: 0.8;
}

.hint {
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  border: 2rpx dashed rgba(45, 212, 191, 0.26);
  background: rgba(255, 255, 255, 0.6);
}

.hintText {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
}

