/**
 * 实干卡片页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ==================== 顶部栏 ==================== */
.topBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
}

.badge {
  padding: 8rpx 14rpx;
  font-size: 20rpx;
  background: rgba(92, 155, 214, 0.1);
  color: #5C9BD6;
  border-radius: 999rpx;
  border: none;
}

/* ==================== 卡片容器 ==================== */
.wrap {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(44, 62, 80, 0.05);
}

.card {
  border-radius: 20rpx;
  padding: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  box-shadow: 0 6rpx 24rpx rgba(92, 155, 214, 0.25);
}

.head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 14rpx;
}

.cardTitle {
  font-size: 32rpx;
  font-weight: 600;
}

.date {
  font-size: 20rpx;
  opacity: 0.85;
}

/* ==================== 数据网格 ==================== */
.grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.cell {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.18);
  padding: 16rpx;
}

.k {
  font-size: 20rpx;
  opacity: 0.85;
  font-weight: 500;
}

.v {
  display: block;
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 600;
}

/* ==================== 详情行 ==================== */
.line {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.lk {
  font-size: 20rpx;
  opacity: 0.85;
  font-weight: 500;
}

.lv {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
}

/* ==================== 底部 ==================== */
.footer {
  display: block;
  margin-top: 14rpx;
  font-size: 20rpx;
  opacity: 0.85;
}

/* ==================== 提示 ==================== */
.hint {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(92, 155, 214, 0.2);
  background: #ffffff;
}

.hintText {
  font-size: 22rpx;
  color: #5D6D7E;
}
