/**
 * 我的页面样式 - 小清新版本
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: linear-gradient(180deg, #F9FBFA 0%, #FCFEF7 50%, #F9FBFA 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.7) 0%, rgba(254, 248, 243, 0.8) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.5rpx;
}

.sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

/* ==================== 入口列表 ==================== */
.entryList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.entry {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  gap: 12rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.entry:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 4rpx 12rpx rgba(61, 61, 61, 0.06);
}

.entry.highlight {
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.1), rgba(184, 230, 219, 0.04));
  border-color: rgba(184, 230, 219, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(184, 230, 219, 0.1);
}

.entry.highlight .entryTitle,
.entry.highlight .entrySub {
  color: #3D3D3D;
}

.entryIcon {
  font-size: 30rpx;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.entryContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.2rpx;
}

.entrySub {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.entryArrow {
  font-size: 26rpx;
  color: #B8C5D6;
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.entry:active .entryArrow {
  transform: translateX(2rpx);
}
