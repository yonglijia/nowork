/**
 * 我的页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ==================== 顶部英雄区域 ==================== */
.hero {
  padding: 28rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #2C3E50;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5D6D7E;
  font-weight: 500;
}

/* ==================== 窝囊费入口（重点样式） ==================== */
.wageEntry {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(92, 155, 214, 0.25);
}

.wageIcon {
  font-size: 40rpx;
}

.wageContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.wageTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.wageSub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.wageEntry .entryArrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 列表入口 ==================== */
.entry {
  padding: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(44, 62, 80, 0.05);
}

.entryText {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.entrySub {
  font-size: 22rpx;
  color: #85929E;
}

.entryArrow {
  font-size: 36rpx;
  color: #9AA5B1;
}
