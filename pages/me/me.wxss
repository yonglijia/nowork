.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 170rpx;
}

.hero {
  padding: 26rpx 24rpx;
  background: radial-gradient(1000rpx 420rpx at 10% 10%, rgba(45, 212, 191, 0.22), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, rgba(153, 246, 228, 0.35), rgba(236, 253, 245, 0.65));
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #064e3b;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
  font-weight: 800;
}

/* 窝囊费入口（重点样式） */
.wageEntry {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 16rpx;
  background: linear-gradient(135deg, #0f766e, #115e59);
  margin: 0 32rpx;
  border-radius: 24rpx;
}

.wageIcon {
  font-size: 48rpx;
}

.wageContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.wageTitle {
  font-size: 32rpx;
  font-weight: 900;
  color: #ffffff;
}

.wageSub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.wageEntry .entryArrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.7);
}

.entry {
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.entryText {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.entryTitle {
  font-size: 30rpx;
  font-weight: 900;
  color: #064e3b;
}

.entrySub {
  font-size: 22rpx;
  color: rgba(17, 94, 89, 0.70);
  font-weight: 800;
}

.entryArrow {
  font-size: 44rpx;
  color: rgba(17, 94, 89, 0.55);
}
