/**
 * 我的页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 170rpx;
  background: #F8FBFB;
}

/* ==================== 顶部英雄区域 ==================== */
.hero {
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 50%, #F8FBFB 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8AA0A2;
  font-weight: 500;
}

/* ==================== 窝囊费入口（重点样式） ==================== */
.wageEntry {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 16rpx;
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  margin: 0 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.25);
}

.wageIcon {
  font-size: 44rpx;
}

.wageContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.wageTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.wageSub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.wageEntry .entryArrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ==================== 列表入口 ==================== */
.entry {
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.entryText {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.entryTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.entrySub {
  font-size: 22rpx;
  color: #8AA0A2;
}

.entryArrow {
  font-size: 40rpx;
  color: #A0B5B7;
}

/* ==================== 分组标题 ==================== */
.sectionHeader {
  padding: 20rpx 24rpx 8rpx;
  font-size: 24rpx;
  color: #A0B5B7;
  font-weight: 500;
}
