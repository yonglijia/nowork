/**
 * 我的页面样式 - Tab4
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5D6D7E;
}

/* ==================== 入口列表 ==================== */
.entryList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.entry {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  gap: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.entry.highlight {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  box-shadow: 0 6rpx 20rpx rgba(92, 155, 214, 0.25);
}

.entry.highlight .entryTitle,
.entry.highlight .entrySub,
.entry.highlight .entryArrow {
  color: #ffffff;
}

.entryIcon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.entryContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.entrySub {
  font-size: 22rpx;
  color: #85929E;
}

.entryArrow {
  font-size: 32rpx;
  color: #9AA5B1;
}
