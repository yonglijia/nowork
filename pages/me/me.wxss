/**
 * 我的页面样式 - 设计感升级版
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(180deg, #F5F8FA 0%, #F9FBFC 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.9) 0%, rgba(245, 249, 255, 0.95) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.5rpx;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #85929E;
}

/* ==================== 入口列表 ==================== */
.entryList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.entry {
  display: flex;
  align-items: center;
  padding: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  gap: 14rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.entry:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 80, 0.08);
}

.entry.highlight {
  background: linear-gradient(135deg, rgba(92, 155, 214, 0.15), rgba(92, 155, 214, 0.05));
  border-color: rgba(92, 155, 214, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(92, 155, 214, 0.12);
}

.entry.highlight .entryTitle,
.entry.highlight .entrySub,
.entry.highlight .entryArrow {
  color: #2C3E50;
}

.entryIcon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
}

.entryContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.3rpx;
}

.entrySub {
  font-size: 22rpx;
  color: #85929E;
}

.entryArrow {
  font-size: 28rpx;
  color: #9AA5B1;
  transition: transform 0.2s ease;
}

.entry:active .entryArrow {
  transform: translateX(4rpx);
}
