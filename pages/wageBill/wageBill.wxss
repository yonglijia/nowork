/**
 * 窝囊费账单页面样式
 * 幽默自嘲、温暖治愈
 */

.page {
  min-height: 100vh;
  background: #F8FBFB;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ==================== 顶部标题 ==================== */
.header {
  padding: 40rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8AA0A2;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  margin: 32rpx;
}

.loadingText {
  font-size: 28rpx;
  color: #8AA0A2;
}

.emptyIcon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
  margin-bottom: 32rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx 32rpx;
}

/* ==================== 月度概览卡片 ==================== */
.overview {
  padding: 32rpx;
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.25);
}

.overviewHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.overviewTitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.modifyBtn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  border: none;
}

.overviewAmount {
  display: flex;
  align-items: baseline;
  margin-bottom: 32rpx;
}

.currency {
  font-size: 36rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.amount {
  font-size: 64rpx;
  font-weight: 700;
}

.overviewStats {
  display: flex;
  justify-content: space-between;
}

.statItem {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.statValue {
  font-size: 28rpx;
  font-weight: 600;
}

.statLabel {
  font-size: 22rpx;
  opacity: 0.8;
}

/* ==================== 今日日报入口 ==================== */
.todayEntry {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.entryIcon {
  font-size: 40rpx;
}

.entryContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.entrySub {
  font-size: 24rpx;
  color: #8AA0A2;
}

.entryArrow {
  font-size: 32rpx;
  color: #A0B5B7;
}

/* ==================== 信息区域 ==================== */
.infoSection {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A5C;
  margin-bottom: 16rpx;
  display: block;
}

.infoList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.infoItem {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(126, 189, 184, 0.1);
}

.infoItem:last-child {
  border-bottom: none;
}

.infoLabel {
  font-size: 26rpx;
  color: #8AA0A2;
}

.infoValue {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A6B6E;
}

/* ==================== 总结文案 ==================== */
.summary {
  padding: 24rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.summaryText {
  font-size: 28rpx;
  color: #5A8A8D;
  font-weight: 500;
  line-height: 1.6;
}

/* ==================== 历史记录 ==================== */
.historySection {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.historyHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.historyToggle {
  font-size: 24rpx;
  color: #8AA0A2;
}

.historyList {
  margin-top: 16rpx;
}

.historyEmpty {
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #A0B5B7;
}

.historyItem {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(126, 189, 184, 0.1);
}

.historyItem:last-child {
  border-bottom: none;
}

.historyMonth {
  flex: 1;
  font-size: 26rpx;
  color: #3D5A5C;
}

.historyWage {
  font-size: 26rpx;
  font-weight: 600;
  color: #7EBDB8;
  margin-right: 12rpx;
}

.historyArrow {
  font-size: 28rpx;
  color: #A0B5B7;
}

/* ==================== 设置弹窗 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 90, 92, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  position: relative;
}

.stepContent {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modalTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
  margin-bottom: 12rpx;
}

.modalDesc {
  font-size: 26rpx;
  color: #8AA0A2;
  margin-bottom: 32rpx;
  text-align: center;
}

.inputWrap {
  width: 100%;
  display: flex;
  align-items: center;
  background: rgba(126, 189, 184, 0.06);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid transparent;
}

.inputWrap:focus-within {
  border-color: rgba(126, 189, 184, 0.3);
}

.inputPrefix {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D5A5C;
  margin-right: 8rpx;
}

.modalInput {
  flex: 1;
  font-size: 32rpx;
  color: #3D5A5C;
}

.pickerValue {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(126, 189, 184, 0.06);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #3D5A5C;
  border: 2rpx solid rgba(126, 189, 184, 0.1);
}

.pickerArrow {
  font-size: 20rpx;
  color: #A0B5B7;
}

.stepBtns {
  width: 100%;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
}

.btn.secondary {
  background: rgba(126, 189, 184, 0.1);
  color: #5A8A8D;
}

.closeBtn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #A0B5B7;
  background: rgba(126, 189, 184, 0.1);
  border-radius: 50%;
}
