/**
 * 窝囊费账单页面样式
 * 幽默自嘲、温暖治愈
 */

.page {
  min-height: 100vh;
  background: #F5F8FA;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

/* ==================== 顶部标题 ==================== */
.header {
  padding: 36rpx 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFCF0 100%);
  border-radius: 0 0 20rpx 20rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 6rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #5D6D7E;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  margin: 24rpx;
}

.loadingText {
  font-size: 26rpx;
  color: #85929E;
}

.emptyIcon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.emptyText {
  font-size: 26rpx;
  color: #85929E;
  margin-bottom: 24rpx;
}

/* ==================== 内容区域 ==================== */
.content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0 24rpx 24rpx;
}

/* ==================== 月度概览卡片 ==================== */
.overview {
  padding: 28rpx;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(92, 155, 214, 0.25);
}

.overviewHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.overviewTitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.modifyBtn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  border: none;
}

.overviewAmount {
  display: flex;
  align-items: baseline;
  margin-bottom: 28rpx;
}

.currency {
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 6rpx;
}

.amount {
  font-size: 60rpx;
  font-weight: 700;
}

.overviewStats {
  display: flex;
  justify-content: space-between;
}

.statItem {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.statValue {
  font-size: 26rpx;
  font-weight: 600;
}

.statLabel {
  font-size: 20rpx;
  opacity: 0.8;
}

/* ==================== 今日日报入口 ==================== */
.todayEntry {
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 14rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.entryIcon {
  font-size: 36rpx;
}

.entryContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.entryTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.entrySub {
  font-size: 22rpx;
  color: #85929E;
}

.entryArrow {
  font-size: 30rpx;
  color: #9AA5B1;
}

/* ==================== 信息区域 ==================== */
.infoSection {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.sectionTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 14rpx;
  display: block;
}

.infoList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.infoItem {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(92, 155, 214, 0.08);
}

.infoItem:last-child {
  border-bottom: none;
}

.infoLabel {
  font-size: 24rpx;
  color: #85929E;
}

.infoValue {
  font-size: 24rpx;
  font-weight: 600;
  color: #34495E;
}

/* ==================== 总结文案 ==================== */
.summary {
  padding: 20rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.summaryText {
  font-size: 26rpx;
  color: #5D6D7E;
  font-weight: 500;
  line-height: 1.6;
}

/* ==================== 历史记录 ==================== */
.historySection {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.historyHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.historyToggle {
  font-size: 22rpx;
  color: #85929E;
}

.historyList {
  margin-top: 14rpx;
}

.historyEmpty {
  padding: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9AA5B1;
}

.historyItem {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(92, 155, 214, 0.08);
}

.historyItem:last-child {
  border-bottom: none;
}

.historyMonth {
  flex: 1;
  font-size: 24rpx;
  color: #2C3E50;
}

.historyWage {
  font-size: 24rpx;
  font-weight: 600;
  color: #5C9BD6;
  margin-right: 10rpx;
}

.historyArrow {
  font-size: 26rpx;
  color: #9AA5B1;
}

/* ==================== 设置弹窗 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 580rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  position: relative;
}

.stepContent {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modalTitle {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 10rpx;
}

.modalDesc {
  font-size: 24rpx;
  color: #5D6D7E;
  margin-bottom: 28rpx;
  text-align: center;
}

.inputWrap {
  width: 100%;
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid transparent;
}

.inputWrap:focus-within {
  border-color: rgba(92, 155, 214, 0.3);
}

.inputPrefix {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-right: 6rpx;
}

.modalInput {
  flex: 1;
  font-size: 30rpx;
  color: #2C3E50;
}

.pickerValue {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F8FAFC;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
}

.pickerArrow {
  font-size: 18rpx;
  color: #9AA5B1;
}

.stepBtns {
  width: 100%;
  display: flex;
  gap: 14rpx;
}

.btn {
  flex: 1;
  padding: 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
}

.btn.secondary {
  background: #F8FAFC;
  color: #5D6D7E;
}

.closeBtn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #9AA5B1;
  background: #F8FAFC;
  border-radius: 50%;
}
