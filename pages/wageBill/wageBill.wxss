.page {
  min-height: 100vh;
  background: #ecfdf5;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.header {
  padding: 32rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #064e3b;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(17, 94, 89, 0.7);
}

.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  margin: 32rpx;
}

.loadingText {
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.6);
}

.emptyIcon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.emptyText {
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.7);
  margin-bottom: 32rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.overview {
  padding: 32rpx;
  background: linear-gradient(135deg, #0f766e, #115e59);
  color: #ffffff;
}

.overviewHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.overviewTitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.modifyBtn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
}

.overviewAmount {
  display: flex;
  align-items: baseline;
  margin-bottom: 32rpx;
}

.currency {
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 8rpx;
}

.amount {
  font-size: 64rpx;
  font-weight: 900;
}

.overviewStats {
  display: flex;
  justify-content: space-between;
}

.statItem {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.statValue {
  font-size: 28rpx;
  font-weight: 700;
}

.statLabel {
  font-size: 22rpx;
  opacity: 0.7;
}

.todayEntry {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
}

.entryIcon {
  font-size: 40rpx;
}

.entryContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.entryTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
}

.entrySub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.entryArrow {
  font-size: 36rpx;
  color: rgba(17, 94, 89, 0.5);
}

.infoSection {
  padding: 24rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
  margin-bottom: 16rpx;
  display: block;
}

.infoList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.infoItem {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(45, 212, 191, 0.1);
}

.infoItem:last-child {
  border-bottom: none;
}

.infoLabel {
  font-size: 26rpx;
  color: rgba(17, 94, 89, 0.7);
}

.infoValue {
  font-size: 26rpx;
  font-weight: 700;
  color: #064e3b;
}

.summary {
  padding: 24rpx;
  text-align: center;
}

.summaryText {
  font-size: 28rpx;
  color: #0f766e;
  font-weight: 500;
}

.historySection {
  padding: 24rpx;
}

.historyHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.historyToggle {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.7);
}

.historyList {
  margin-top: 16rpx;
}

.historyEmpty {
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: rgba(17, 94, 89, 0.5);
}

.historyItem {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(45, 212, 191, 0.1);
}

.historyItem:last-child {
  border-bottom: none;
}

.historyMonth {
  flex: 1;
  font-size: 26rpx;
  color: #064e3b;
}

.historyWage {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f766e;
  margin-right: 12rpx;
}

.historyArrow {
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.5);
}

/* 弹窗 */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  position: relative;
}

.stepContent {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modalTitle {
  font-size: 36rpx;
  font-weight: 900;
  color: #064e3b;
  margin-bottom: 12rpx;
}

.modalDesc {
  font-size: 26rpx;
  color: rgba(17, 94, 89, 0.7);
  margin-bottom: 32rpx;
}

.inputWrap {
  width: 100%;
  display: flex;
  align-items: center;
  background: rgba(45, 212, 191, 0.08);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.inputPrefix {
  font-size: 32rpx;
  font-weight: 700;
  color: #064e3b;
  margin-right: 8rpx;
}

.modalInput {
  flex: 1;
  font-size: 32rpx;
  color: #0f172a;
}

.pickerValue {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(45, 212, 191, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #064e3b;
}

.pickerArrow {
  font-size: 20rpx;
  color: rgba(17, 94, 89, 0.5);
}

.stepBtns {
  width: 100%;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #2dd4bf, #34d399);
  color: #ffffff;
}

.btn.secondary {
  background: rgba(45, 212, 191, 0.1);
  color: #115e59;
}

.closeBtn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.5);
}
