.page {
  min-height: 100vh;
  background: #ecfdf5;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.header {
  padding: 32rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #064e3b;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(17, 94, 89, 0.7);
}

.scoreArea {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scoreDisplay {
  display: flex;
  align-items: baseline;
  margin-bottom: 32rpx;
}

.scoreNum {
  font-size: 100rpx;
  font-weight: 900;
  color: #0f766e;
  line-height: 1;
}

.scoreLabel {
  font-size: 32rpx;
  color: rgba(17, 94, 89, 0.6);
  margin-left: 8rpx;
}

.scoreSlider {
  width: 100%;
  margin: 16rpx 0;
}

.scoreLabels {
  width: 100%;
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.label {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.6);
}

.quickScore {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.scoreBtn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(45, 212, 191, 0.1);
  border: 2rpx solid rgba(45, 212, 191, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #115e59;
}

.scoreBtn.active {
  background: #2dd4bf;
  border-color: #2dd4bf;
  color: #ffffff;
}

.actions {
  padding: 0 32rpx;
}

.btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #2dd4bf, #34d399);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(45, 212, 191, 0.3);
}

.btn.secondary {
  background: rgba(45, 212, 191, 0.1);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.3);
}

.guidance {
  margin: 0 32rpx;
  padding: 32rpx;
}

.guidanceTitle {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
  margin-bottom: 16rpx;
}

.guidanceText {
  display: block;
  font-size: 32rpx;
  color: #0f172a;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.guidanceActions {
  margin-top: 16rpx;
}

.guidanceActions .btn {
  width: auto;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}
