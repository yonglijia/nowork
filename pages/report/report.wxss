/**
 * 举报页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: #F8FBFB;
}

/* ==================== 顶部区域 ==================== */
.hero {
  padding: 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8AA0A2;
  font-weight: 500;
}

/* ==================== 数据区块 ==================== */
.block {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.blockTop {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.blockTitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.blockHint {
  font-size: 22rpx;
  color: #A0B5B7;
  font-weight: 500;
}

/* ==================== 统计网格 ==================== */
.stats {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.s {
  border-radius: 20rpx;
  padding: 18rpx;
  background: rgba(126, 189, 184, 0.06);
  border: 1rpx solid rgba(126, 189, 184, 0.1);
}

.k {
  font-size: 22rpx;
  color: #8AA0A2;
  font-weight: 500;
}

.v {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #7EBDB8;
}

/* ==================== 备注说明 ==================== */
.note {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.noteTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.noteText {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7A9A9D;
  line-height: 1.5;
}
