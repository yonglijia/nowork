.page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero {
  padding: 26rpx 24rpx;
  background: radial-gradient(1000rpx 420rpx at 10% 10%, rgba(45, 212, 191, 0.22), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, rgba(153, 246, 228, 0.35), rgba(236, 253, 245, 0.65));
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #064e3b;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
  font-weight: 800;
}

.block {
  padding: 24rpx;
}

.blockTop {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.blockTitle {
  font-size: 30rpx;
  font-weight: 900;
  color: #064e3b;
}

.blockHint {
  font-size: 22rpx;
  color: rgba(17, 94, 89, 0.60);
  font-weight: 900;
}

.stats {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.s {
  border-radius: 22rpx;
  padding: 18rpx 18rpx;
  background: rgba(45, 212, 191, 0.10);
  border: 2rpx solid rgba(45, 212, 191, 0.16);
}

.k {
  font-size: 22rpx;
  color: rgba(17, 94, 89, 0.65);
  font-weight: 900;
}

.v {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #0f766e;
}

.note {
  padding: 22rpx 22rpx;
}

.noteTitle {
  font-size: 26rpx;
  font-weight: 900;
  color: #064e3b;
}

.noteText {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.70);
  font-weight: 800;
  line-height: 1.35;
}

