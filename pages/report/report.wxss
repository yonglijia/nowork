/**
 * 举报页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ==================== 顶部区域 ==================== */
.hero {
  padding: 28rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2C3E50;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5D6D7E;
  font-weight: 500;
}

/* ==================== 数据区块 ==================== */
.block {
  padding: 22rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.blockTop {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10rpx;
}

.blockTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.blockHint {
  font-size: 20rpx;
  color: #9AA5B1;
  font-weight: 500;
}

/* ==================== 统计网格 ==================== */
.stats {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
}

.s {
  border-radius: 14rpx;
  padding: 16rpx;
  background: #F8FAFC;
  border: none;
}

.k {
  font-size: 20rpx;
  color: #85929E;
  font-weight: 500;
}

.v {
  display: block;
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #5C9BD6;
}

/* ==================== 备注说明 ==================== */
.note {
  padding: 22rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.noteTitle {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E50;
}

.noteText {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5D6D7E;
  line-height: 1.5;
}
