/**
 * 吐槽墙页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: #F8FBFB;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.headerTop {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.sub {
  font-size: 24rpx;
  color: #8AA0A2;
}

/* ==================== 发布区域 ==================== */
.composer {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  border: 1rpx solid rgba(126, 189, 184, 0.1);
  padding: 20rpx;
}

.input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #3D5A5C;
}

.composerBottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.count {
  font-size: 22rpx;
  color: #A0B5B7;
}

.send {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  font-weight: 600;
  font-size: 26rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(126, 189, 184, 0.25);
  border: none;
}

/* ==================== 列表 ==================== */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

.empty {
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  text-align: center;
}

.emptyText {
  font-size: 26rpx;
  color: #8AA0A2;
}

.item {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.itemText {
  font-size: 30rpx;
  line-height: 1.5;
  color: #3D5A5C;
  font-weight: 500;
}

.itemTime {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #A0B5B7;
}
