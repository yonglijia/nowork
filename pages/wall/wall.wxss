/**
 * 吐槽墙页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 28rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.headerTop {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
}

.sub {
  font-size: 24rpx;
  color: #5D6D7E;
}

/* ==================== 发布区域 ==================== */
.composer {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
  padding: 18rpx;
}

.input {
  width: 100%;
  min-height: 140rpx;
  font-size: 26rpx;
  color: #2C3E50;
}

.composerBottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.count {
  font-size: 20rpx;
  color: #9AA5B1;
}

.send {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  font-weight: 600;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(92, 155, 214, 0.25);
  border: none;
}

/* ==================== 列表 ==================== */
.list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
}

.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

.item {
  padding: 22rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.itemText {
  font-size: 28rpx;
  line-height: 1.5;
  color: #2C3E50;
  font-weight: 500;
}

.itemTime {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #9AA5B1;
}
