.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.breathArea {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
}

/* 外发光效果 - 使用 CSS 变量实现平滑过渡 */
.glowRing {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(45, 212, 191, 0.3) 0%, rgba(16, 185, 129, 0.1) 40%, transparent 70%);
  filter: blur(30rpx);
}

/* 粒子容器 */
.particleContainer {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #5eead4, #2dd4bf);
  box-shadow: 0 0 20rpx rgba(45, 212, 191, 0.8), 0 0 40rpx rgba(45, 212, 191, 0.4);
  will-change: transform, opacity;
}

/* 主圆圈 */
.circleOuter {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 10;
}

.circleInner {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(45, 212, 191, 0.9), rgba(16, 185, 129, 0.7));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 0 60rpx rgba(45, 212, 191, 0.5),
    0 0 120rpx rgba(45, 212, 191, 0.3),
    inset 0 0 40rpx rgba(255, 255, 255, 0.2);
  transition: transform 0.15s ease-out;
}

.circleInner.idle {
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.1));
  box-shadow: none;
}

.circleInner.paused {
  opacity: 0.7;
}

.breathText {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.5);
}

.timeText {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffffff;
  margin-top: 8rpx;
  text-shadow: 0 0 30rpx rgba(255, 255, 255, 0.5);
}

.progressBar {
  width: 80%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  margin: 40rpx 0;
  overflow: hidden;
}

.progressFill {
  height: 100%;
  background: linear-gradient(90deg, #2dd4bf, #34d399, #5eead4);
  border-radius: 4rpx;
  box-shadow: 0 0 20rpx rgba(45, 212, 191, 0.5);
}

.controls {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.btn {
  min-width: 200rpx;
  padding: 24rpx 48rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #2dd4bf, #34d399);
  color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(45, 212, 191, 0.5);
}

.btn.secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.moodEntry {
  width: 90%;
  padding: 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  text-align: center;
  margin-top: 20rpx;
}

.moodEntryTitle {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #064e3b;
  margin-bottom: 24rpx;
}

.moodEntry .btn {
  width: 100%;
}
