/**
 * 呼吸放松页面样式
 * 清晰、治愈、放松
 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #F5F9FF 50%, #F5F8FA 100%);
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

/* ==================== 顶部标题 ==================== */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #5D6D7E;
  line-height: 1.5;
}

/* ==================== 呼吸动画区域 ==================== */
.breathArea {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
}

/* 外发光效果 */
.glowRing {
  position: absolute;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(92, 155, 214, 0.2) 0%, rgba(92, 155, 214, 0.05) 40%, transparent 70%);
  filter: blur(30rpx);
}

/* 粒子容器 */
.particleContainer {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #8BB8E0, #5C9BD6);
  box-shadow: 0 0 12rpx rgba(92, 155, 214, 0.5);
  will-change: transform, opacity;
}

/* 主圆圈 */
.circleOuter {
  width: 380rpx;
  height: 380rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 10;
  box-shadow: 0 4rpx 24rpx rgba(92, 155, 214, 0.15);
}

.circleInner {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 6rpx 24rpx rgba(92, 155, 214, 0.3),
    inset 0 2rpx 16rpx rgba(255, 255, 255, 0.3);
  transition: transform 0.15s ease-out;
}

.circleInner.idle {
  background: linear-gradient(135deg, #E3F2FD, #F5F9FF);
  box-shadow: 
    0 4rpx 16rpx rgba(92, 155, 214, 0.1),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.5);
}

.circleInner.paused {
  opacity: 0.8;
}

.breathText {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.circleInner.idle .breathText {
  color: #5C9BD6;
}

.timeText {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-top: 6rpx;
}

.circleInner.idle .timeText {
  color: #5C9BD6;
}

/* ==================== 进度条 ==================== */
.progressBar {
  width: 80%;
  height: 8rpx;
  background: rgba(92, 155, 214, 0.15);
  border-radius: 4rpx;
  margin: 32rpx 0;
  overflow: hidden;
}

.progressFill {
  height: 100%;
  background: linear-gradient(90deg, #5C9BD6, #6BA3DC, #8BB8E0);
  border-radius: 4rpx;
}

/* ==================== 控制按钮 ==================== */
.controls {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.btn {
  min-width: 180rpx;
  padding: 22rpx 40rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(92, 155, 214, 0.3);
}

.btn.secondary {
  background: #ffffff;
  color: #5C9BD6;
  border: 2rpx solid rgba(92, 155, 214, 0.25);
}

/* ==================== 情绪打分入口 ==================== */
.moodEntry {
  width: 90%;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
  margin-top: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(44, 62, 80, 0.05);
}

.moodEntryTitle {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.moodEntry .btn {
  width: 100%;
}
