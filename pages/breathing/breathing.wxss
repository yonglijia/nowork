/**
 * 呼吸放松页面样式
 * 柔和、治愈、放松
 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E0F2F1 0%, #F1F8F7 50%, #F8FBFB 100%);
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

/* ==================== 顶部标题 ==================== */
.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8AA0A2;
  line-height: 1.5;
}

/* ==================== 呼吸动画区域 ==================== */
.breathArea {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
}

/* 外发光效果 - 柔和的治愈青色 */
.glowRing {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(126, 189, 184, 0.25) 0%, rgba(126, 189, 184, 0.08) 40%, transparent 70%);
  filter: blur(40rpx);
}

/* 粒子容器 */
.particleContainer {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #A5D4D0, #7EBDB8);
  box-shadow: 0 0 16rpx rgba(126, 189, 184, 0.5);
  will-change: transform, opacity;
}

/* 主圆圈 */
.circleOuter {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 10;
  box-shadow: 0 8rpx 40rpx rgba(126, 189, 184, 0.15);
}

.circleInner {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 8rpx 32rpx rgba(126, 189, 184, 0.3),
    inset 0 2rpx 20rpx rgba(255, 255, 255, 0.3);
  transition: transform 0.15s ease-out;
}

.circleInner.idle {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.7));
  box-shadow: 
    0 4rpx 20rpx rgba(126, 189, 184, 0.1),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.5);
}

.circleInner.paused {
  opacity: 0.8;
}

.breathText {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.circleInner.idle .breathText {
  color: #7EBDB8;
}

.timeText {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  margin-top: 8rpx;
}

.circleInner.idle .timeText {
  color: #5A8A8D;
}

/* ==================== 进度条 ==================== */
.progressBar {
  width: 80%;
  height: 8rpx;
  background: rgba(126, 189, 184, 0.15);
  border-radius: 4rpx;
  margin: 40rpx 0;
  overflow: hidden;
}

.progressFill {
  height: 100%;
  background: linear-gradient(90deg, #7EBDB8, #8FC4C0, #A5D4D0);
  border-radius: 4rpx;
  box-shadow: 0 0 12rpx rgba(126, 189, 184, 0.4);
}

/* ==================== 控制按钮 ==================== */
.controls {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.btn {
  min-width: 200rpx;
  padding: 24rpx 48rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(126, 189, 184, 0.3);
}

.btn.secondary {
  background: rgba(255, 255, 255, 0.9);
  color: #5A8A8D;
  border: 2rpx solid rgba(126, 189, 184, 0.2);
}

/* ==================== 情绪打分入口 ==================== */
.moodEntry {
  width: 90%;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.06);
}

.moodEntryTitle {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
  margin-bottom: 20rpx;
}

.moodEntry .btn {
  width: 100%;
}
