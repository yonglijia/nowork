/**
 * 拒绝文案列表页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.headerTitle {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.favEntry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.favEntryText {
  font-size: 22rpx;
  color: #85929E;
}

.favEntryArrow {
  font-size: 24rpx;
  color: #9AA5B1;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  gap: 10rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
}

.searchInput {
  flex: 1;
  font-size: 26rpx;
  color: #34495E;
}

.searchInput::placeholder {
  color: #9AA5B1;
}

.clearBtn {
  font-size: 28rpx;
  color: #9AA5B1;
  padding: 0 6rpx;
}

/* ==================== 分类栏 ==================== */
.categoryBar {
  padding: 12rpx 0;
}

.categoryScroll {
  white-space: nowrap;
}

.categoryItem {
  display: inline-block;
  padding: 12rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #5D6D7E;
  background: #ffffff;
  border: 1rpx solid rgba(92, 155, 214, 0.12);
}

.categoryItem.active {
  background: #5C9BD6;
  border-color: #5C9BD6;
  color: #ffffff;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.loadingText,
.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

/* ==================== 文案列表 ==================== */
.scriptList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.scriptItem {
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.scriptCategory {
  display: inline-block;
  align-self: flex-start;
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  color: #5C9BD6;
  background: rgba(92, 155, 214, 0.1);
  border-radius: 999rpx;
  border: none;
}

.scriptText {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.5;
}

.scriptActions {
  display: flex;
  gap: 14rpx;
  margin-top: 6rpx;
}

.actionBtn {
  flex: 1;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.copyBtn {
  background: rgba(92, 155, 214, 0.1);
  color: #5C9BD6;
}

.favBtn {
  background: #ffffff;
  color: #5D6D7E;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
}

.favBtn.favorited {
  background: #5C9BD6;
  color: #ffffff;
  border-color: #5C9BD6;
}
