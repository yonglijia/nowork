/**
 * 拒绝文案列表页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 40rpx;
  background: #F8FBFB;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.headerTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.favEntry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.favEntryText {
  font-size: 24rpx;
  color: #8AA0A2;
}

.favEntryArrow {
  font-size: 28rpx;
  color: #A0B5B7;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  border: 1rpx solid rgba(126, 189, 184, 0.1);
}

.searchInput {
  flex: 1;
  font-size: 28rpx;
  color: #4A6B6E;
}

.searchInput::placeholder {
  color: #A0B5B7;
}

.clearBtn {
  font-size: 32rpx;
  color: #A0B5B7;
  padding: 0 8rpx;
}

/* ==================== 分类栏 ==================== */
.categoryBar {
  padding: 16rpx 0;
}

.categoryScroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.categoryItem {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #5A8A8D;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(126, 189, 184, 0.15);
}

.categoryItem.active {
  background: #7EBDB8;
  border-color: #7EBDB8;
  color: #ffffff;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loadingText,
.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
}

/* ==================== 文案列表 ==================== */
.scriptList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.scriptItem {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.scriptCategory {
  display: inline-block;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #5A8A8D;
  background: rgba(126, 189, 184, 0.1);
  border-radius: 999rpx;
  border: none;
}

.scriptText {
  font-size: 30rpx;
  color: #3D5A5C;
  line-height: 1.5;
}

.scriptActions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.actionBtn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.copyBtn {
  background: rgba(126, 189, 184, 0.1);
  color: #5A8A8D;
}

.favBtn {
  background: #ffffff;
  color: #5A8A8D;
  border: 1rpx solid rgba(126, 189, 184, 0.2);
}

.favBtn.favorited {
  background: #7EBDB8;
  color: #ffffff;
  border-color: #7EBDB8;
}
