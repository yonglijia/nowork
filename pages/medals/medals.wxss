/**
 * 勋章页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: #F8FBFB;
}

/* ==================== 顶部区域 ==================== */
.top {
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8AA0A2;
  font-weight: 500;
}

/* ==================== 空状态 ==================== */
.empty {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  text-align: center;
}

.emptyText {
  font-size: 26rpx;
  color: #8AA0A2;
}

/* ==================== 勋章网格 ==================== */
.grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

.medal {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.medalTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.medalName {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.medalTag {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  background: rgba(126, 189, 184, 0.12);
  color: #5A8A8D;
  border-radius: 999rpx;
  border: none;
}

.medalDesc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7A9A9D;
  line-height: 1.5;
}

.medalTime {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #A0B5B7;
}
