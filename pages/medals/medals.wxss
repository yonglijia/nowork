.page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.top {
  padding: 26rpx 24rpx;
  background: radial-gradient(1000rpx 420rpx at 10% 10%, rgba(45, 212, 191, 0.22), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, rgba(153, 246, 228, 0.35), rgba(236, 253, 245, 0.65));
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #064e3b;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
  font-weight: 800;
}

.empty {
  padding: 26rpx 22rpx;
}

.emptyText {
  font-size: 26rpx;
  color: rgba(17, 94, 89, 0.78);
  font-weight: 900;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medal {
  padding: 22rpx 22rpx;
}

.medalTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.medalName {
  font-size: 30rpx;
  font-weight: 900;
  color: #064e3b;
}

.medalTag {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  background: rgba(45, 212, 191, 0.16);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.22);
}

.medalDesc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.72);
  font-weight: 800;
  line-height: 1.35;
}

.medalTime {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(17, 94, 89, 0.55);
  font-weight: 800;
}

