/**
 * 勋章页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ==================== 顶部区域 ==================== */
.top {
  padding: 28rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFCF0 100%);
  border-radius: 20rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2C3E50;
}

.sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5D6D7E;
  font-weight: 500;
}

/* ==================== 空状态 ==================== */
.empty {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
}

.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

/* ==================== 勋章网格 ==================== */
.grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.medal {
  padding: 22rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.medalTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.medalName {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.medalTag {
  padding: 8rpx 14rpx;
  font-size: 20rpx;
  background: rgba(92, 155, 214, 0.1);
  color: #5C9BD6;
  border-radius: 999rpx;
  border: none;
}

.medalDesc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5D6D7E;
  line-height: 1.5;
}

.medalTime {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #9AA5B1;
}
