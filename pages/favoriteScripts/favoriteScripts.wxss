/**
 * 收藏文案列表页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.headerTitle {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.editBtn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #5C9BD6;
  background: rgba(92, 155, 214, 0.1);
  border-radius: 999rpx;
  border: none;
}

.headerSub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #85929E;
}

/* ==================== 批量操作栏 ==================== */
.batchBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.selectAllBtn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #5D6D7E;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(92, 155, 214, 0.3);
  background: #ffffff;
}

.checkbox.checked {
  background: #5C9BD6;
  border-color: #5C9BD6;
}

.checkbox.checked::after {
  content: "✓";
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: bold;
}

.deleteBtn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  background: #EBA0A0;
  border-radius: 999rpx;
  border: none;
}

.deleteBtn[disabled] {
  opacity: 0.5;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 10rpx;
}

.loadingText,
.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

.emptySub {
  font-size: 22rpx;
  color: #9AA5B1;
}

/* ==================== 收藏列表 ==================== */
.favoriteList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.favItem {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  gap: 14rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.favItem.selected {
  background: #E3F2FD;
}

.selectBox {
  display: flex;
  align-items: center;
  padding-top: 6rpx;
}

.favContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.favCategory {
  display: inline-block;
  align-self: flex-start;
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  color: #5C9BD6;
  background: rgba(92, 155, 214, 0.1);
  border-radius: 999rpx;
  border: none;
}

.favText {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.5;
}

.favActions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
}

.copyBtn,
.removeBtn {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 10rpx;
  border: none;
}

.copyBtn {
  background: rgba(92, 155, 214, 0.1);
  color: #5C9BD6;
}

.removeBtn {
  background: #ffffff;
  color: #B87070;
  border: 1rpx solid rgba(184, 112, 112, 0.2);
}
