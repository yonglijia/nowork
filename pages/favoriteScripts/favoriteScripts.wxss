/**
 * 收藏文案列表页面样式
 * 温暖、治愈、简洁
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 40rpx;
  background: #F8FBFB;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.headerTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.editBtn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #5A8A8D;
  background: rgba(126, 189, 184, 0.1);
  border-radius: 999rpx;
  border: none;
}

.headerSub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8AA0A2;
}

/* ==================== 批量操作栏 ==================== */
.batchBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.selectAllBtn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #5A8A8D;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(126, 189, 184, 0.3);
  background: #ffffff;
}

.checkbox.checked {
  background: #7EBDB8;
  border-color: #7EBDB8;
}

.checkbox.checked::after {
  content: "✓";
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.deleteBtn {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  background: #EBA0A0;
  border-radius: 999rpx;
  border: none;
}

.deleteBtn[disabled] {
  opacity: 0.5;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 12rpx;
}

.loadingText,
.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
}

.emptySub {
  font-size: 24rpx;
  color: #A0B5B7;
}

/* ==================== 收藏列表 ==================== */
.favoriteList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.favItem {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.favItem.selected {
  background: rgba(126, 189, 184, 0.06);
}

.selectBox {
  display: flex;
  align-items: center;
  padding-top: 8rpx;
}

.favContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.favCategory {
  display: inline-block;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #5A8A8D;
  background: rgba(126, 189, 184, 0.1);
  border-radius: 999rpx;
  border: none;
}

.favText {
  font-size: 30rpx;
  color: #3D5A5C;
  line-height: 1.5;
}

.favActions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.copyBtn,
.removeBtn {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.copyBtn {
  background: rgba(126, 189, 184, 0.1);
  color: #5A8A8D;
}

.removeBtn {
  background: #ffffff;
  color: #C87070;
  border: 1rpx solid rgba(200, 112, 112, 0.2);
}
