.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 40rpx;
}

.header {
  padding: 24rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.headerTitle {
  font-size: 36rpx;
  font-weight: 900;
  color: #064e3b;
}

.editBtn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #115e59;
  background: rgba(45, 212, 191, 0.12);
  border-radius: 999rpx;
}

.headerSub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.batchBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.selectAllBtn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #115e59;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(45, 212, 191, 0.4);
  background: #ffffff;
}

.checkbox.checked {
  background: #2dd4bf;
  border-color: #2dd4bf;
}

.checkbox.checked::after {
  content: "✓";
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.deleteBtn {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  background: #ef4444;
  border-radius: 999rpx;
}

.deleteBtn[disabled] {
  opacity: 0.5;
}

.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 12rpx;
}

.loadingText,
.emptyText {
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.6);
}

.emptySub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.45);
}

.favoriteList {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 32rpx;
}

.favItem {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  gap: 16rpx;
}

.favItem.selected {
  background: rgba(45, 212, 191, 0.08);
}

.selectBox {
  display: flex;
  align-items: center;
  padding-top: 8rpx;
}

.favContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.favCategory {
  display: inline-block;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  color: #115e59;
  background: rgba(45, 212, 191, 0.12);
  border-radius: 999rpx;
  border: 1rpx solid rgba(45, 212, 191, 0.2);
}

.favText {
  font-size: 30rpx;
  color: #0f172a;
  line-height: 1.5;
}

.favActions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.copyBtn,
.removeBtn {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 12rpx;
}

.copyBtn {
  background: rgba(45, 212, 191, 0.12);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.25);
}

.removeBtn {
  background: #ffffff;
  color: #ef4444;
  border: 2rpx solid rgba(239, 68, 68, 0.3);
}
