/**
 * 收藏音频页面样式
 * 温暖、治愈、简洁
 */

.page {
  min-height: 100vh;
  background: #F5F8FA;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 180rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 0 0 20rpx 20rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.editBtn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #5C9BD6;
  background: rgba(92, 155, 214, 0.1);
  border-radius: 999rpx;
  border: none;
}

.headerSub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #85929E;
}

/* ==================== 批量操作栏 ==================== */
.batchBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 24rpx;
}

.selectAllBtn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #5D6D7E;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(92, 155, 214, 0.3);
  background: #ffffff;
}

.checkbox.checked {
  background: #5C9BD6;
  border-color: #5C9BD6;
}

.checkbox.checked::after {
  content: "✓";
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: bold;
}

.deleteBtn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  background: #EBA0A0;
  border-radius: 999rpx;
  border: none;
}

.deleteBtn[disabled] {
  opacity: 0.5;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 10rpx;
}

.loadingText,
.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

.emptySub {
  font-size: 22rpx;
  color: #9AA5B1;
}

/* ==================== 音频列表 ==================== */
.audioList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 0 24rpx;
}

.audioItem {
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 14rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.audioItem.selected {
  background: #E3F2FD;
  border: 1rpx solid rgba(92, 155, 214, 0.2);
}

.selectBox {
  display: flex;
  align-items: center;
}

.audioIcon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #5D6D7E;
}

.audioContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.audioTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.audioDesc {
  font-size: 22rpx;
  color: #85929E;
}

.audioFav {
  padding: 10rpx;
  font-size: 26rpx;
  color: #C8D4DC;
}

.audioFav.favorited {
  color: #EBA0A0;
}

/* ==================== 播放器底栏 ==================== */
.playerBar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(44, 62, 80, 0.06);
}

.playerInfo {
  flex: 1;
}

.playerTitle {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E50;
}

.playerControls {
  display: flex;
  gap: 10rpx;
}

.playerBtn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #5D6D7E;
}
