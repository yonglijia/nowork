.page {
  min-height: 100vh;
  background: #ecfdf5;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 200rpx;
}

.header {
  padding: 24rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 36rpx;
  font-weight: 900;
  color: #064e3b;
}

.editBtn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #115e59;
  background: rgba(45, 212, 191, 0.12);
  border-radius: 999rpx;
}

.headerSub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.batchBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.selectAllBtn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #115e59;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(45, 212, 191, 0.4);
  background: #ffffff;
}

.checkbox.checked {
  background: #2dd4bf;
  border-color: #2dd4bf;
}

.checkbox.checked::after {
  content: "✓";
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.deleteBtn {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  background: #ef4444;
  border-radius: 999rpx;
}

.deleteBtn[disabled] {
  opacity: 0.5;
}

.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 12rpx;
}

.loadingText,
.emptyText {
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.6);
}

.emptySub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.45);
}

.audioList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 32rpx;
}

.audioItem {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
}

.audioItem.selected {
  background: rgba(45, 212, 191, 0.08);
}

.selectBox {
  display: flex;
  align-items: center;
}

.audioIcon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(45, 212, 191, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #115e59;
}

.audioContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.audioTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
}

.audioDesc {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.audioFav {
  padding: 12rpx;
  font-size: 28rpx;
  color: rgba(17, 94, 89, 0.5);
}

.playerBar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.playerInfo {
  flex: 1;
}

.playerTitle {
  font-size: 26rpx;
  font-weight: 700;
  color: #064e3b;
}

.playerControls {
  display: flex;
  gap: 16rpx;
}

.playerBtn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(45, 212, 191, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #115e59;
}
