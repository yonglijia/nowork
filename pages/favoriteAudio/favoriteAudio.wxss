/**
 * 收藏音频页面样式
 * 温暖、治愈、简洁
 */

.page {
  min-height: 100vh;
  background: #F8FBFB;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 200rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.editBtn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #5A8A8D;
  background: rgba(126, 189, 184, 0.1);
  border-radius: 999rpx;
  border: none;
}

.headerSub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8AA0A2;
}

/* ==================== 批量操作栏 ==================== */
.batchBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.selectAllBtn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #5A8A8D;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(126, 189, 184, 0.3);
  background: #ffffff;
}

.checkbox.checked {
  background: #7EBDB8;
  border-color: #7EBDB8;
}

.checkbox.checked::after {
  content: "✓";
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.deleteBtn {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  background: #EBA0A0;
  border-radius: 999rpx;
  border: none;
}

.deleteBtn[disabled] {
  opacity: 0.5;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 12rpx;
}

.loadingText,
.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
}

.emptySub {
  font-size: 24rpx;
  color: #A0B5B7;
}

/* ==================== 音频列表 ==================== */
.audioList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.audioItem {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.audioItem.selected {
  background: rgba(126, 189, 184, 0.08);
  border: 2rpx solid rgba(126, 189, 184, 0.2);
}

.selectBox {
  display: flex;
  align-items: center;
}

.audioIcon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(126, 189, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #5A8A8D;
}

.audioContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.audioTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.audioDesc {
  font-size: 24rpx;
  color: #8AA0A2;
}

.audioFav {
  padding: 12rpx;
  font-size: 28rpx;
  color: #C8D8D8;
}

.audioFav.favorited {
  color: #EBA0A0;
}

/* ==================== 播放器底栏 ==================== */
.playerBar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(61, 90, 92, 0.08);
}

.playerInfo {
  flex: 1;
}

.playerTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.playerControls {
  display: flex;
  gap: 12rpx;
}

.playerBtn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(126, 189, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #5A8A8D;
}
