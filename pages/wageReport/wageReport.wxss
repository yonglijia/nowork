/**
 * 窝囊费日报页面样式
 * 幽默自嘲、温暖治愈
 */

.page {
  min-height: 100vh;
  background: #F8FBFB;
  display: flex;
  flex-direction: column;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 20rpx;
}

.loadingText {
  font-size: 28rpx;
  color: #8AA0A2;
}

.emptyIcon {
  font-size: 80rpx;
  opacity: 0.6;
}

.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
}

/* ==================== 内容区域 ==================== */
.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx;
}

/* ==================== 顶部大数字展示 ==================== */
.hero {
  padding: 48rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.25);
}

.heroTitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.heroAmount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.currency {
  font-size: 40rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.amount {
  font-size: 72rpx;
  font-weight: 700;
}

.heroSub {
  font-size: 26rpx;
  opacity: 0.8;
}

/* ==================== 明细区域 ==================== */
.detail,
.info {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A5C;
  margin-bottom: 16rpx;
  display: block;
}

.detailList,
.infoList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detailItem,
.infoItem {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(126, 189, 184, 0.1);
}

.detailItem:last-child,
.infoItem:last-child {
  border-bottom: none;
}

.detailLabel,
.infoLabel {
  font-size: 26rpx;
  color: #8AA0A2;
}

.detailValue,
.infoValue {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A6B6E;
}

.detailValue.highlight {
  color: #7EBDB8;
}

/* ==================== 治愈自嘲文案 ==================== */
.comfort {
  padding: 32rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.6), rgba(224, 242, 241, 0.4));
  border-radius: 20rpx;
}

.comfortText {
  font-size: 30rpx;
  color: #4A6B6E;
  font-weight: 500;
  line-height: 1.7;
}

/* ==================== 操作按钮 ==================== */
.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(126, 189, 184, 0.25);
}

.btn.secondary {
  background: #ffffff;
  color: #5A8A8D;
  border: 2rpx solid rgba(126, 189, 184, 0.2);
}
