/**
 * 窝囊费日报页面样式
 * 幽默自嘲、温暖治愈
 */

.page {
  min-height: 100vh;
  background: #F5F8FA;
  display: flex;
  flex-direction: column;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 16rpx;
}

.loadingText {
  font-size: 26rpx;
  color: #85929E;
}

.emptyIcon {
  font-size: 72rpx;
  opacity: 0.5;
}

.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

/* ==================== 内容区域 ==================== */
.content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 20rpx;
}

/* ==================== 顶部大数字展示 ==================== */
.hero {
  padding: 40rpx 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(92, 155, 214, 0.25);
}

.heroTitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 14rpx;
}

.heroAmount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 14rpx;
}

.currency {
  font-size: 36rpx;
  font-weight: 600;
  margin-right: 6rpx;
}

.amount {
  font-size: 68rpx;
  font-weight: 700;
}

.heroSub {
  font-size: 24rpx;
  opacity: 0.85;
}

/* ==================== 明细区域 ==================== */
.detail,
.info {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.sectionTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 14rpx;
  display: block;
}

.detailList,
.infoList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detailItem,
.infoItem {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(92, 155, 214, 0.08);
}

.detailItem:last-child,
.infoItem:last-child {
  border-bottom: none;
}

.detailLabel,
.infoLabel {
  font-size: 24rpx;
  color: #85929E;
}

.detailValue,
.infoValue {
  font-size: 24rpx;
  font-weight: 600;
  color: #34495E;
}

.detailValue.highlight {
  color: #5C9BD6;
}

/* ==================== 治愈自嘲文案 ==================== */
.comfort {
  padding: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 16rpx;
}

.comfortText {
  font-size: 28rpx;
  color: #34495E;
  font-weight: 500;
  line-height: 1.7;
}

/* ==================== 操作按钮 ==================== */
.actions {
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
}

.btn {
  flex: 1;
  padding: 22rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(92, 155, 214, 0.25);
}

.btn.secondary {
  background: #ffffff;
  color: #5C9BD6;
  border: 2rpx solid rgba(92, 155, 214, 0.2);
}
