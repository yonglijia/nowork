.page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.hero {
  padding: 26rpx 24rpx;
  background: radial-gradient(1000rpx 400rpx at 10% 10%, rgba(45, 212, 191, 0.22), rgba(255,255,255,0) 60%),
    radial-gradient(900rpx 360rpx at 90% 30%, rgba(167, 243, 208, 0.35), rgba(255,255,255,0) 55%),
    linear-gradient(135deg, rgba(153, 246, 228, 0.35), rgba(236, 253, 245, 0.65));
  border-color: rgba(45, 212, 191, 0.22);
}

.heroTop {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.heroTitleRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.heroTitle {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  color: #064e3b;
}

.heroBadge {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  background: rgba(45, 212, 191, 0.16);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.22);
}

.heroSub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #064e3b;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picked {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.moodBar {
  padding: 24rpx;
}

.tagRow {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(45, 212, 191, 0.10);
  border: 2rpx solid rgba(45, 212, 191, 0.20);
  color: #115e59;
  font-size: 26rpx;
}

.tag.active {
  background: #2dd4bf;
  border-color: #2dd4bf;
  color: #ffffff;
}

.section {
  padding: 24rpx;
}

.presetGrid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.presetBtn {
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid rgba(45, 212, 191, 0.16);
  border-radius: 22rpx;
  padding: 26rpx 18rpx;
  font-size: 26rpx;
  color: #115e59;
  line-height: 1.2;
  box-shadow: 0 10rpx 22rpx rgba(17, 94, 89, 0.06);
}

.cardWrap {
  padding: 24rpx;
}

.card {
  background: radial-gradient(900rpx 360rpx at 10% 0%, rgba(153, 246, 228, 0.28), rgba(255,255,255,0) 55%),
    radial-gradient(900rpx 360rpx at 100% 40%, rgba(45, 212, 191, 0.28), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, #0f766e, #115e59);
  border-radius: 26rpx;
  padding: 22rpx;
  color: rgba(255, 255, 255, 0.98);
}

.memeBox {
  height: 320rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.memeImg {
  width: 100%;
  height: 100%;
}

.memeEmoji {
  font-size: 140rpx;
}

.cardText {
  display: block;
  margin-top: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.cardFooter {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  opacity: 0.7;
}

.actions {
  margin-top: 18rpx;
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.actionBtn {
  flex: 1;
  min-width: 0;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #115e59;
  padding: 22rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.wallEntry {
  padding: 26rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wallText {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wallTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #064e3b;
}

.wallSub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.72);
}

.wallArrow {
  font-size: 44rpx;
  color: rgba(17, 94, 89, 0.55);
  margin-left: 20rpx;
}

.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}

/* 快速减负模块 */
.reduceSection {
  padding: 24rpx;
}

.reduceGrid {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reduceItem {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(45, 212, 191, 0.06);
  border-radius: 18rpx;
  gap: 16rpx;
}

.reduceIcon {
  font-size: 40rpx;
  width: 60rpx;
  text-align: center;
}

.reduceContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reduceTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
}

.reduceDesc {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.reduceArrow {
  font-size: 36rpx;
  color: rgba(17, 94, 89, 0.5);
}

/* 弹窗样式 */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  flex-shrink: 0;
}

.modalTitle {
  font-size: 32rpx;
  font-weight: 900;
  color: #064e3b;
  text-align: center;
}

.modalInput {
  width: 100%;
  height: 80rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  background: rgba(45, 212, 191, 0.08);
  border-radius: 16rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.modalInput::placeholder {
  color: rgba(17, 94, 89, 0.5);
}

.modalActions {
  display: flex;
  gap: 16rpx;
}

.modalBtn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.4;
}

.cancelBtn {
  background: rgba(45, 212, 191, 0.1);
  color: #115e59;
}

.confirmBtn {
  background: linear-gradient(135deg, #2dd4bf, #34d399);
  color: #ffffff;
}

.deleteBtn {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

/* 今日治愈模块 */
.healingSection {
  padding: 24rpx;
}

.healingHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.healingAudioEntry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.healingAudioText {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.7);
}

.healingAudioArrow {
  font-size: 32rpx;
  color: rgba(17, 94, 89, 0.55);
}

.healingQuote {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(45, 212, 191, 0.1), rgba(16, 185, 129, 0.08));
  border-radius: 18rpx;
  margin-bottom: 20rpx;
}

.quoteText {
  font-size: 30rpx;
  color: #064e3b;
  line-height: 1.6;
  font-weight: 500;
}

.healingActions {
  display: flex;
  gap: 16rpx;
}

.healingBtn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(45, 212, 191, 0.12);
  border-radius: 18rpx;
  border: 2rpx solid rgba(45, 212, 191, 0.2);
}

.healingBtnIcon {
  font-size: 36rpx;
}

.healingBtnText {
  font-size: 28rpx;
  font-weight: 700;
  color: #064e3b;
}

