.page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.hero {
  padding: 26rpx 24rpx;
  background: radial-gradient(1000rpx 400rpx at 10% 10%, rgba(45, 212, 191, 0.22), rgba(255,255,255,0) 60%),
    radial-gradient(900rpx 360rpx at 90% 30%, rgba(167, 243, 208, 0.35), rgba(255,255,255,0) 55%),
    linear-gradient(135deg, rgba(153, 246, 228, 0.35), rgba(236, 253, 245, 0.65));
  border-color: rgba(45, 212, 191, 0.22);
}

.heroTop {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.heroTitleRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.heroTitle {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  color: #064e3b;
}

.heroBadge {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  background: rgba(45, 212, 191, 0.16);
  color: #115e59;
  border: 2rpx solid rgba(45, 212, 191, 0.22);
}

.heroSub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.78);
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #064e3b;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picked {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.65);
}

.moodBar {
  padding: 24rpx;
}

.tagRow {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(45, 212, 191, 0.10);
  border: 2rpx solid rgba(45, 212, 191, 0.20);
  color: #115e59;
  font-size: 26rpx;
}

.tag.active {
  background: #2dd4bf;
  border-color: #2dd4bf;
  color: #ffffff;
}

.section {
  padding: 24rpx;
}

.presetGrid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.presetBtn {
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid rgba(45, 212, 191, 0.16);
  border-radius: 22rpx;
  padding: 26rpx 18rpx;
  font-size: 26rpx;
  color: #115e59;
  line-height: 1.2;
  box-shadow: 0 10rpx 22rpx rgba(17, 94, 89, 0.06);
}

.cardWrap {
  padding: 24rpx;
}

.card {
  background: radial-gradient(900rpx 360rpx at 10% 0%, rgba(153, 246, 228, 0.28), rgba(255,255,255,0) 55%),
    radial-gradient(900rpx 360rpx at 100% 40%, rgba(45, 212, 191, 0.28), rgba(255,255,255,0) 60%),
    linear-gradient(135deg, #0f766e, #115e59);
  border-radius: 26rpx;
  padding: 22rpx;
  color: rgba(255, 255, 255, 0.98);
}

.memeBox {
  height: 320rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.memeImg {
  width: 100%;
  height: 100%;
}

.memeEmoji {
  font-size: 140rpx;
}

.cardText {
  display: block;
  margin-top: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.cardFooter {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  opacity: 0.7;
}

.actions {
  margin-top: 18rpx;
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.actionBtn {
  flex: 1;
  min-width: 0;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #115e59;
  padding: 22rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.wallEntry {
  padding: 26rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wallText {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wallTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #064e3b;
}

.wallSub {
  font-size: 24rpx;
  color: rgba(17, 94, 89, 0.72);
}

.wallArrow {
  font-size: 44rpx;
  color: rgba(17, 94, 89, 0.55);
  margin-left: 20rpx;
}

.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}

