/**
 * 首页样式
 * 温暖、治愈、轻幽默
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: #F8FBFB;
}

/* ==================== 顶部英雄区域 ==================== */
.hero {
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #E0F2F1 0%, #F1F8F7 50%, #F8FBFB 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.heroTop {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.heroTitleRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.heroTitle {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #3D5A5C;
}

.heroBadge {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  background: rgba(126, 189, 184, 0.15);
  color: #5A8A8D;
  border-radius: 999rpx;
  border: none;
}

.heroSub {
  font-size: 26rpx;
  color: #7A9A9D;
  line-height: 1.5;
}

/* ==================== 区块标题 ==================== */
.sectionTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picked {
  font-size: 24rpx;
  color: #8AA0A2;
}

/* ==================== 心情标签区域 ==================== */
.moodBar {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.05);
}

.tagRow {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(126, 189, 184, 0.1);
  border: 2rpx solid rgba(126, 189, 184, 0.15);
  color: #5A8A8D;
  font-size: 26rpx;
  font-weight: 500;
}

.tag.active {
  background: #7EBDB8;
  border-color: #7EBDB8;
  color: #ffffff;
}

/* ==================== 区块容器 ==================== */
.section {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.05);
}

/* ==================== 预设按钮网格 ==================== */
.presetGrid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.presetBtn {
  background: rgba(126, 189, 184, 0.06);
  border: none;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  font-size: 26rpx;
  color: #4A6B6E;
  line-height: 1.4;
  text-align: left;
  box-shadow: none;
}

.presetBtn:active {
  background: rgba(126, 189, 184, 0.12);
}

/* ==================== 拒绝文案卡片 ==================== */
.cardWrap {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.05);
}

.card {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  border-radius: 20rpx;
  padding: 28rpx;
  color: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(126, 189, 184, 0.25);
}

.memeBox {
  height: 320rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.memeImg {
  width: 100%;
  height: 100%;
}

.memeEmoji {
  font-size: 120rpx;
}

.cardText {
  display: block;
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.5;
}

.cardFooter {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  opacity: 0.8;
}

/* ==================== 操作按钮 ==================== */
.actions {
  margin-top: 20rpx;
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.actionBtn {
  flex: 1;
  min-width: 0;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #5A8A8D;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  box-shadow: none;
  border: none;
}

.actionBtn:active {
  background: rgba(126, 189, 184, 0.1);
}

/* ==================== 吐槽墙入口 ==================== */
.wallEntry {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wallText {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wallTitle {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.wallSub {
  font-size: 24rpx;
  color: #8AA0A2;
}

.wallArrow {
  font-size: 40rpx;
  color: #A0B5B7;
  margin-left: 20rpx;
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}

/* ==================== 快速减负模块 ==================== */
.reduceSection {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.05);
}

.reduceGrid {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reduceItem {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(126, 189, 184, 0.06);
  border-radius: 16rpx;
  gap: 16rpx;
}

.reduceIcon {
  font-size: 36rpx;
  width: 56rpx;
  text-align: center;
}

.reduceContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reduceTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.reduceDesc {
  font-size: 24rpx;
  color: #8AA0A2;
}

.reduceArrow {
  font-size: 32rpx;
  color: #A0B5B7;
}

/* ==================== 弹窗样式 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 90, 92, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 600rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  flex-shrink: 0;
}

.modalTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
  text-align: center;
}

.modalInput {
  width: 100%;
  height: 96rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  background: rgba(126, 189, 184, 0.06);
  border-radius: 20rpx;
  color: #3D5A5C;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.modalInput:focus {
  border-color: rgba(126, 189, 184, 0.3);
}

.modalInput::placeholder {
  color: #A0B5B7;
}

.modalActions {
  display: flex;
  gap: 16rpx;
}

.modalBtn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
  border: none;
}

.cancelBtn {
  background: rgba(126, 189, 184, 0.1);
  color: #5A8A8D;
}

.confirmBtn {
  background: linear-gradient(135deg, #7EBDB8, #8FC4C0);
  color: #ffffff;
}

.deleteBtn {
  background: rgba(235, 160, 160, 0.15);
  color: #C87070;
}

/* ==================== 今日治愈模块 ==================== */
.healingSection {
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(61, 90, 92, 0.05);
}

.healingHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.healingAudioEntry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.healingAudioText {
  font-size: 24rpx;
  color: #8AA0A2;
}

.healingAudioArrow {
  font-size: 28rpx;
  color: #A0B5B7;
}

.healingQuote {
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.6), rgba(224, 242, 241, 0.4));
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.quoteText {
  font-size: 30rpx;
  color: #4A6B6E;
  line-height: 1.6;
  font-weight: 500;
}

.healingActions {
  display: flex;
  gap: 16rpx;
}

.healingBtn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(126, 189, 184, 0.1);
  border-radius: 16rpx;
  border: none;
}

.healingBtn:active {
  background: rgba(126, 189, 184, 0.18);
}

.healingBtnIcon {
  font-size: 32rpx;
}

.healingBtnText {
  font-size: 28rpx;
  font-weight: 600;
  color: #5A8A8D;
}
