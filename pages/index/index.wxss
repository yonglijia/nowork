/**
 * 首页样式 - 重构版
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: #F5F8FA;
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 20rpx;
}

.headerTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
}

.todayDate {
  font-size: 24rpx;
  color: #5D6D7E;
}

.moodRow {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.moodLabel {
  font-size: 24rpx;
  color: #5D6D7E;
}

.moodTags {
  display: flex;
  gap: 10rpx;
}

.moodTag {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  color: #5D6D7E;
  background: #ffffff;
  border-radius: 999rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
}

.moodTag.active {
  background: #5C9BD6;
  color: #ffffff;
  border-color: #5C9BD6;
}

/* ==================== 通用区块样式 ==================== */
.section {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.sectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.sectionLink {
  font-size: 24rpx;
  color: #5C9BD6;
}

/* ==================== 模块1：今日嘴硬（重新设计） ==================== */
.ventSection {
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFBF0 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.15);
}

.ventHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ventTitle {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ventEmoji {
  font-size: 32rpx;
}

.ventTitleText {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.ventLink {
  font-size: 24rpx;
  color: #B8860B;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
}

/* 吐槽按钮 - 横向滚动列表 */
.ventScroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.ventBtnList {
  display: inline-flex;
  gap: 12rpx;
}

.ventBtn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  min-width: 100rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(184, 134, 11, 0.12);
  box-shadow: 0 2rpx 8rpx rgba(184, 134, 11, 0.06);
}

.ventBtn:active {
  transform: scale(0.96);
  background: rgba(255, 193, 7, 0.1);
}

.ventBtnEmoji {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.ventBtnText {
  font-size: 22rpx;
  color: #5D6D7E;
  font-weight: 500;
}

/* 卡片预览 - 新设计 */
.cardPreview {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(184, 134, 11, 0.1);
}

.cardTop {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.cardEmojiWrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFE082, #FFD54F);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.cardTextWrap {
  flex: 1;
  padding-top: 4rpx;
}

.cardText {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.5;
}

.cardActions {
  display: flex;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(184, 134, 11, 0.08);
}

.cardBtn {
  flex: 1;
  padding: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: #FFF8E1;
  color: #B8860B;
  border-radius: 12rpx;
  border: none;
}

.cardBtn.primary {
  background: linear-gradient(135deg, #FFD54F, #FFCA28);
  color: #5D4E37;
}

/* ==================== 模块2：今日实干 ==================== */
.effortEntry {
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  text-align: center;
}

.effortHint {
  font-size: 26rpx;
  color: #85929E;
}

/* ==================== 模块3：今日治愈 ==================== */
.quoteBox {
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  margin-bottom: 14rpx;
}

.quoteText {
  font-size: 26rpx;
  color: #34495E;
  line-height: 1.5;
}

.healingActions {
  display: flex;
  gap: 12rpx;
}

.healingBtn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.healingIcon {
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.healingText {
  font-size: 22rpx;
  color: #34495E;
}

/* ==================== 模块4：快速减负 ==================== */
.reduceList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.reduceItem {
  display: flex;
  align-items: center;
  padding: 14rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  gap: 12rpx;
}

.reduceIcon {
  font-size: 28rpx;
}

.reduceContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reduceTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.reduceDesc {
  font-size: 22rpx;
  color: #85929E;
}

.reduceArrow {
  font-size: 28rpx;
  color: #9AA5B1;
}

/* ==================== 模块5：今日窝囊费 ==================== */
.wageCard {
  padding: 20rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFFCF0);
  border-radius: 12rpx;
  text-align: center;
}

.wageAmount {
  display: flex;
  justify-content: center;
  align-items: baseline;
}

.wageCurrency {
  font-size: 28rpx;
  font-weight: 600;
  color: #9A7B4F;
}

.wageNum {
  font-size: 48rpx;
  font-weight: 700;
  color: #9A7B4F;
}

.wageHint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #B5A07A;
}

/* ==================== 弹窗 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modalContent {
  width: 560rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.modalTitle {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 20rpx;
}

.modalInput {
  width: 100%;
  padding: 18rpx;
  font-size: 28rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  color: #2C3E50;
  box-sizing: border-box;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
}

.modalActions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.modalBtn {
  flex: 1;
  padding: 18rpx;
  font-size: 26rpx;
  background: #F8FAFC;
  color: #5D6D7E;
  border-radius: 12rpx;
  border: none;
}

.modalBtn.primary {
  background: #5C9BD6;
  color: #ffffff;
}

.modalBtn.danger {
  background: rgba(235, 160, 160, 0.15);
  color: #B87070;
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}
