/**
 * 首页样式 - 设计感升级版
 * 核心：分层色彩、渐变背景、精致排版、微交互
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(180deg, #F5F8FA 0%, #F9FBFC 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 - 品牌感 ==================== */
.header {
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.9) 0%, rgba(245, 249, 255, 0.95) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.08);
}

.headerTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.slogan {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.todayDate {
  font-size: 24rpx;
  color: #85929E;
  font-weight: 500;
}

.moodRow {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.moodLabel {
  font-size: 24rpx;
  color: #5D6D7E;
  font-weight: 500;
}

.moodTags {
  display: flex;
  gap: 8rpx;
}

.moodTag {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  color: #5D6D7E;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 999rpx;
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.moodTag:active {
  transform: scale(0.96);
}

.moodTag.active {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.3);
}

/* ==================== 通用区块 ==================== */
.section {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
  transition: all 0.3s ease;
}

.section:active {
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 80, 0.06);
  transform: translateY(1rpx);
}

.sectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: -0.3rpx;
}

.sectionLink {
  font-size: 24rpx;
  color: #5C9BD6;
  font-weight: 500;
  transition: color 0.2s ease;
}

.sectionLink:active {
  color: #4A7BA7;
}

/* ==================== 模块1：今日嘴硬 ==================== */
.ventSection {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(255, 224, 130, 0.15) 0%, rgba(255, 248, 225, 0.8) 100%);
  border-radius: 20rpx;
  border: 1.5rpx solid rgba(255, 208, 79, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.08);
}

.ventHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ventTitle {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ventEmoji {
  font-size: 32rpx;
  animation: bounce 2s ease-in-out infinite;
}

.ventTitleText {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E50;
}

.ventLink {
  font-size: 22rpx;
  color: #B8860B;
  padding: 8rpx 14rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 999rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.ventLink:active {
  background: rgba(255, 255, 255, 0.9);
  transform: scale(0.95);
}

.ventScroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.ventBtnList {
  display: inline-flex;
  gap: 12rpx;
}

.ventBtn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 18rpx;
  min-width: 100rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1.5rpx solid rgba(255, 208, 79, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.1);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.ventBtn:active {
  transform: scale(0.95);
  background: rgba(255, 248, 225, 0.7);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.15);
}

.ventBtnEmoji {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.ventBtnText {
  font-size: 22rpx;
  color: #5D6D7E;
  font-weight: 600;
}

.cardPreview {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.12);
  border: 1rpx solid rgba(255, 208, 79, 0.12);
}

.cardTop {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.cardEmojiWrap {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFE082, #FFD54F);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.2);
  flex-shrink: 0;
}

.cardTextWrap {
  flex: 1;
  padding-top: 6rpx;
}

.cardText {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.5;
  font-weight: 500;
}

.cardActions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 208, 79, 0.12);
}

.cardBtn {
  flex: 1;
  padding: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: #FFF8E1;
  color: #9A7B4F;
  border-radius: 12rpx;
  border: none;
  transition: all 0.2s ease;
}

.cardBtn:active {
  transform: scale(0.96);
}

.cardBtn.primary {
  background: linear-gradient(135deg, #FFD54F, #FFCA28);
  color: #5D4E37;
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.2);
}

/* ==================== 模块2-5 通用 ==================== */
.effortEntry,
.quoteBox,
.healingBtn,
.reduceItem {
  transition: all 0.2s ease;
}

.effortEntry {
  padding: 24rpx;
  background: linear-gradient(135deg, #F0F7FF, #F8FAFC);
  border-radius: 12rpx;
  text-align: center;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
}

.effortHint {
  font-size: 26rpx;
  color: #85929E;
  line-height: 1.5;
}

.quoteBox {
  padding: 18rpx;
  background: linear-gradient(135deg, rgba(227, 242, 253, 0.6), rgba(255, 248, 225, 0.4));
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.1);
}

.quoteText {
  font-size: 26rpx;
  color: #2C3E50;
  line-height: 1.6;
  font-weight: 500;
  letter-spacing: 0.2rpx;
}

.healingActions {
  display: flex;
  gap: 12rpx;
}

.healingBtn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx;
  background: linear-gradient(135deg, rgba(128, 222, 234, 0.1), rgba(77, 208, 225, 0.05));
  border-radius: 12rpx;
  border: 1rpx solid rgba(128, 222, 234, 0.15);
}

.healingBtn:active {
  background: linear-gradient(135deg, rgba(128, 222, 234, 0.15), rgba(77, 208, 225, 0.1));
  transform: scale(0.96);
}

.healingIcon {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.healingText {
  font-size: 22rpx;
  color: #34495E;
  font-weight: 500;
}

.reduceList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.reduceItem {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #F9FBFC, #FCFDFE);
  border-radius: 12rpx;
  gap: 12rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.08);
}

.reduceItem:active {
  background: rgba(92, 155, 214, 0.05);
}

.reduceIcon {
  font-size: 28rpx;
}

.reduceContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reduceTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.reduceDesc {
  font-size: 22rpx;
  color: #85929E;
}

.reduceArrow {
  font-size: 28rpx;
  color: #9AA5B1;
}

/* ==================== 模块5：窝囊费 ==================== */
.wageCard {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(255, 224, 130, 0.12), rgba(255, 248, 225, 0.8));
  border-radius: 14rpx;
  text-align: center;
  border: 1.5rpx solid rgba(255, 208, 79, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.08);
}

.wageAmount {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 4rpx;
}

.wageCurrency {
  font-size: 28rpx;
  font-weight: 600;
  color: #9A7B4F;
}

.wageNum {
  font-size: 48rpx;
  font-weight: 700;
  color: #9A7B4F;
  letter-spacing: -1rpx;
}

.wageHint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #B5A07A;
}

/* ==================== 弹窗 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(4rpx);
  animation: fadeIn 0.2s ease;
}

.modalContent {
  width: 560rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(44, 62, 80, 0.15);
}

.modalTitle {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 18rpx;
}

.modalInput {
  width: 100%;
  padding: 16rpx;
  font-size: 26rpx;
  background: rgba(92, 155, 214, 0.06);
  border-radius: 12rpx;
  color: #2C3E50;
  box-sizing: border-box;
  border: 1.5rpx solid rgba(92, 155, 214, 0.15);
  transition: all 0.2s ease;
}

.modalInput:focus {
  border-color: #5C9BD6;
  background: rgba(92, 155, 214, 0.1);
}

.modalActions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.modalBtn {
  flex: 1;
  padding: 16rpx;
  font-size: 26rpx;
  background: rgba(92, 155, 214, 0.08);
  color: #5D6D7E;
  border-radius: 12rpx;
  border: none;
  font-weight: 600;
  transition: all 0.2s ease;
}

.modalBtn:active {
  transform: scale(0.96);
}

.modalBtn.primary {
  background: linear-gradient(135deg, #5C9BD6, #6BA3DC);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(92, 155, 214, 0.25);
}

.modalBtn.danger {
  background: rgba(235, 160, 160, 0.12);
  color: #B87070;
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}

/* ==================== 动画 ==================== */
@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  25% {
    transform: translateY(-4rpx);
  }
  75% {
    transform: translateY(2rpx);
  }
}
