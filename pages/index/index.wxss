/**
 * 首页样式 - 小清新版本
 * 设计：清新、极简、治愈、温柔
 */

.page {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: linear-gradient(180deg, #F9FBFA 0%, #FCFEF7 50%, #F9FBFA 100%);
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.7) 0%, rgba(254, 248, 243, 0.8) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.08);
}

.headerTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 32rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

.todayDate {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.moodRow {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.moodLabel {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 600;
}

.moodTags {
  display: flex;
  gap: 8rpx;
}

.moodTag {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #6B7280;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 999rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.15);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-weight: 600;
}

.moodTag:active {
  transform: scale(0.92);
}

.moodTag.active {
  background: linear-gradient(135deg, #B8E6DB, #A0D9CF);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.3);
}

/* ==================== 通用区块 ==================== */
.section {
  padding: 18rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(61, 61, 61, 0.04);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.section:active {
  transform: translateY(1rpx) scale(0.99);
  box-shadow: 0 4rpx 12rpx rgba(61, 61, 61, 0.06);
}

.sectionHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 800;
  color: #3D3D3D;
  letter-spacing: -0.3rpx;
}

.sectionLink {
  font-size: 24rpx;
  color: #7EC8B8;
  font-weight: 600;
  transition: color 0.2s ease;
}

.sectionLink:active {
  color: #6BA497;
  opacity: 0.8;
}

/* ==================== 模块1：今日嘴硬 ==================== */
.ventSection {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(255, 245, 220, 0.6), rgba(255, 251, 237, 0.9));
  border-radius: 18rpx;
  border: 1.5rpx solid rgba(255, 235, 180, 0.25);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.08);
}

.ventHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.ventTitle {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ventEmoji {
  font-size: 30rpx;
  animation: floatGentle 3s ease-in-out infinite;
}

.ventTitleText {
  font-size: 28rpx;
  font-weight: 800;
  color: #3D3D3D;
}

.ventLink {
  font-size: 22rpx;
  color: #B8860B;
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 999rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  border: 1rpx solid rgba(255, 214, 79, 0.1);
}

.ventLink:active {
  background: rgba(255, 255, 255, 0.8);
  transform: scale(0.94);
}

.ventScroll {
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.ventBtnList {
  display: inline-flex;
  gap: 10rpx;
}

.ventBtn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 16rpx;
  min-width: 96rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1.5rpx solid rgba(255, 214, 79, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.08);
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.ventBtn:active {
  transform: scale(0.92);
  background: rgba(255, 251, 237, 0.6);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.12);
}

.ventBtnEmoji {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.ventBtnText {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: 700;
}

.cardPreview {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.1);
  border: 1rpx solid rgba(255, 214, 79, 0.1);
}

.cardTop {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.cardEmojiWrap {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, rgba(255, 224, 130, 0.7), rgba(255, 214, 79, 0.6));
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 3rpx 10rpx rgba(255, 193, 7, 0.15);
  flex-shrink: 0;
}

.cardTextWrap {
  flex: 1;
  padding-top: 4rpx;
}

.cardText {
  font-size: 28rpx;
  color: #3D3D3D;
  line-height: 1.5;
  font-weight: 600;
}

.cardActions {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 214, 79, 0.1);
}

.cardBtn {
  flex: 1;
  padding: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: #FFF9EE;
  color: #9A7B4F;
  border-radius: 10rpx;
  border: none;
  transition: all 0.2s ease;
}

.cardBtn:active {
  transform: scale(0.94);
}

.cardBtn.primary {
  background: linear-gradient(135deg, rgba(255, 224, 130, 0.6), rgba(255, 214, 79, 0.5));
  color: #5D4E37;
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.15);
}

/* ==================== 模块2-5 通用 ==================== */
.effortEntry {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.5), rgba(248, 250, 252, 0.8));
  border-radius: 12rpx;
  text-align: center;
  border: 1rpx solid rgba(184, 230, 219, 0.1);
}

.effortHint {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.5;
  font-weight: 500;
}

.quoteBox {
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(232, 247, 243, 0.4), rgba(244, 217, 230, 0.3));
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.1);
}

.quoteText {
  font-size: 26rpx;
  color: #3D3D3D;
  line-height: 1.6;
  font-weight: 600;
  letter-spacing: 0.1rpx;
}

.healingActions {
  display: flex;
  gap: 10rpx;
}

.healingBtn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(184, 230, 219, 0.08), rgba(184, 230, 219, 0.04));
  border-radius: 12rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.12);
  transition: all 0.2s ease;
}

.healingBtn:active {
  background: rgba(184, 230, 219, 0.12);
  transform: scale(0.96);
}

.healingIcon {
  font-size: 26rpx;
  margin-bottom: 6rpx;
}

.healingText {
  font-size: 22rpx;
  color: #3D3D3D;
  font-weight: 700;
}

.reduceList {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reduceItem {
  display: flex;
  align-items: center;
  padding: 14rpx;
  background: linear-gradient(135deg, #FCFEF7, #FAFCFB);
  border-radius: 12rpx;
  gap: 10rpx;
  border: 1rpx solid rgba(184, 230, 219, 0.08);
  transition: all 0.2s ease;
}

.reduceItem:active {
  background: rgba(184, 230, 219, 0.05);
  transform: scale(0.98);
}

.reduceIcon {
  font-size: 26rpx;
}

.reduceContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
}

.reduceTitle {
  font-size: 26rpx;
  font-weight: 700;
  color: #3D3D3D;
}

.reduceDesc {
  font-size: 22rpx;
  color: #9CA3AF;
}

.reduceArrow {
  font-size: 26rpx;
  color: #B8C5D6;
  transition: transform 0.2s ease;
}

.reduceItem:active .reduceArrow {
  transform: translateX(2rpx);
}

/* ==================== 模块5：窝囊费 ==================== */
.wageCard {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(255, 245, 220, 0.5), rgba(255, 251, 237, 0.7));
  border-radius: 14rpx;
  text-align: center;
  border: 1.5rpx solid rgba(255, 214, 79, 0.12);
  box-shadow: 0 3rpx 10rpx rgba(255, 193, 7, 0.08);
}

.wageAmount {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 3rpx;
}

.wageCurrency {
  font-size: 26rpx;
  font-weight: 700;
  color: #9A7B4F;
}

.wageNum {
  font-size: 44rpx;
  font-weight: 800;
  color: #9A7B4F;
  letter-spacing: -1rpx;
}

.wageHint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #B8A080;
  font-weight: 500;
}

/* ==================== 弹窗 ==================== */
.modalMask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 61, 61, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(3rpx);
  animation: fadeIn 0.2s ease;
}

.modalContent {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(61, 61, 61, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
}

.modalTitle {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #3D3D3D;
  text-align: center;
  margin-bottom: 16rpx;
}

.modalInput {
  width: 100%;
  padding: 14rpx;
  font-size: 26rpx;
  background: rgba(184, 230, 219, 0.08);
  border-radius: 10rpx;
  color: #3D3D3D;
  box-sizing: border-box;
  border: 1.5rpx solid rgba(184, 230, 219, 0.15);
  transition: all 0.2s ease;
  font-weight: 600;
}

.modalInput:focus {
  border-color: #B8E6DB;
  background: rgba(184, 230, 219, 0.12);
  box-shadow: 0 0 0 3rpx rgba(184, 230, 219, 0.1);
}

.modalActions {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
}

.modalBtn {
  flex: 1;
  padding: 14rpx;
  font-size: 26rpx;
  background: rgba(184, 230, 219, 0.08);
  color: #6B7280;
  border-radius: 10rpx;
  border: none;
  font-weight: 700;
  transition: all 0.2s ease;
}

.modalBtn:active {
  transform: scale(0.94);
}

.modalBtn.primary {
  background: linear-gradient(135deg, #B8E6DB, #A0D9CF);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(184, 230, 219, 0.25);
}

.modalBtn.danger {
  background: rgba(244, 217, 230, 0.12);
  color: #E89DB8;
}

/* ==================== 隐藏画布 ==================== */
.hiddenCanvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  width: 900px;
  height: 1200px;
}

/* ==================== 动画 ==================== */
@keyframes floatGentle {
  0%, 100% {
    transform: translateY(0) rotateZ(-1deg);
  }
  50% {
    transform: translateY(-6rpx) rotateZ(1deg);
  }
}
