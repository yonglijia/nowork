<view class="page">
  <!-- 顶部：Slogan + 日期 + 情绪标签 -->
  <view class="header">
    <view class="headerTop">
      <text class="slogan">嘴上不想上班，身体超能干</text>
      <text class="todayDate">{{todayDate}}</text>
    </view>
    <view class="moodRow">
      <text class="moodLabel">今日心情：</text>
      <view class="moodTags">
        <view
          wx:for="{{moodTags}}"
          wx:key="*this"
          class="moodTag {{selectedMood === item ? 'active' : ''}}"
          bindtap="onMoodTap"
          data-tag="{{item}}"
        >{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 模块1：今日嘴硬（重新设计） -->
  <view class="ventSection">
    <view class="ventHeader">
      <view class="ventTitle">
        <text class="ventEmoji">😤</text>
        <text class="ventTitleText">今日嘴硬</text>
      </view>
      <text class="ventLink" bindtap="goWall">嘴硬墙 ›</text>
    </view>
    
    <!-- 吐槽按钮 - 横向滚动 -->
    <scroll-view class="ventScroll" scroll-x>
      <view class="ventBtnList">
        <view
          wx:for="{{presets}}"
          wx:key="key"
          class="ventBtn"
          bindtap="onPresetTap"
          data-key="{{item.key}}"
        >
          <text class="ventBtnEmoji">{{item.emoji || '💢'}}</text>
          <text class="ventBtnText">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
    
    <!-- 卡片预览 -->
    <view wx:if="{{card}}" class="cardPreview">
      <view class="cardTop">
        <view class="cardEmojiWrap">
          <text>{{card.meme.value}}</text>
        </view>
        <view class="cardTextWrap">
          <text class="cardText">{{card.text}}</text>
        </view>
      </view>
      <view class="cardActions">
        <button class="cardBtn" bindtap="onSaveImage">保存图片</button>
        <button class="cardBtn primary" open-type="share">分享出去</button>
      </view>
    </view>
  </view>

  <!-- 模块2：今日实干 -->
  <view class="section">
    <view class="sectionHeader">
      <text class="sectionTitle">✅ 今日实干</text>
      <text class="sectionLink" bindtap="goEffort">去记录 ›</text>
    </view>
    <view class="effortEntry" bindtap="goEffort">
      <text class="effortHint">点击进入实干记录，记录今日付出</text>
    </view>
  </view>

  <!-- 模块3：今日治愈 -->
  <view class="section">
    <view class="sectionHeader">
      <text class="sectionTitle">🌸 今日治愈</text>
      <text class="sectionLink" bindtap="goHealingAudio">治愈音频 ›</text>
    </view>
    <view wx:if="{{healingQuote}}" class="quoteBox">
      <text class="quoteText">{{healingQuote.quote}}</text>
    </view>
    <view class="healingActions">
      <view class="healingBtn" bindtap="goBreathing">
        <text class="healingIcon">🌬️</text>
        <text class="healingText">1分钟呼吸放松</text>
      </view>
      <view class="healingBtn" bindtap="goMoodScore">
        <text class="healingIcon">📊</text>
        <text class="healingText">情绪打分</text>
      </view>
    </view>
  </view>

  <!-- 模块4：快速减负 -->
  <view class="section">
    <view class="sectionHeader">
      <text class="sectionTitle">🎯 快速减负</text>
    </view>
    <view class="reduceList">
      <view class="reduceItem" bindtap="showTopTaskEdit">
        <text class="reduceIcon">📌</text>
        <view class="reduceContent">
          <text class="reduceTitle">今日最重要1件事</text>
          <text class="reduceDesc">{{topTask ? topTask.text : '点击设置'}}</text>
        </view>
        <text class="reduceArrow">›</text>
      </view>
      <view class="reduceItem" bindtap="goRefusalScripts">
        <text class="reduceIcon">💬</text>
        <view class="reduceContent">
          <text class="reduceTitle">拒绝话术</text>
          <text class="reduceDesc">学会说「不」</text>
        </view>
        <text class="reduceArrow">›</text>
      </view>
    </view>
  </view>

  <!-- 模块5：今日窝囊费 -->
  <view wx:if="{{hasWageConfig}}" class="section">
    <view class="sectionHeader">
      <text class="sectionTitle">💰 今日窝囊费</text>
      <text class="sectionLink" bindtap="goWageReport">详情 ›</text>
    </view>
    <view class="wageCard" bindtap="goWageReport">
      <view class="wageAmount">
        <text class="wageCurrency">¥</text>
        <text class="wageNum">{{todayWage.totalWage || '0.00'}}</text>
      </view>
      <text class="wageHint">点击查看今日窝囊费日报</text>
    </view>
  </view>

  <canvas type="2d" id="shareCanvas" class="hiddenCanvas"></canvas>

  <!-- 设置弹窗 -->
  <view wx:if="{{showTopTaskInput}}" class="modalMask" bindtap="hideTopTaskEdit">
    <view class="modalContent" catchtap="">
      <text class="modalTitle">今日最重要1件事</text>
      <input 
        class="modalInput"
        placeholder="输入内容，最多20字"
        maxlength="20"
        value="{{topTaskInputValue}}"
        bindinput="onTopTaskInput"
        focus="{{showTopTaskInput}}"
      />
      <view class="modalActions">
        <button wx:if="{{topTask}}" class="modalBtn danger" bindtap="removeTopTask">删除</button>
        <button class="modalBtn" bindtap="hideTopTaskEdit">取消</button>
        <button class="modalBtn primary" bindtap="saveTopTask">保存</button>
      </view>
    </view>
  </view>
</view>
