<view class="safePage page">
  <view class="hero cardSurface">
    <view class="heroTop">
      <view class="heroTitleRow">
        <text class="heroTitle">今日嘴硬</text>
        <text class="heroBadge pill">安全发泄区</text>
      </view>
      <text class="heroSub">幽默自嘲一下，心情就松一口气</text>
    </view>
  </view>

  <!-- 快速减负模块 -->
  <view class="reduceSection cardSurface">
    <text class="sectionTitle">快速减负</text>
    <view class="reduceGrid">
      <!-- 今日最重要1件事 -->
      <view class="reduceItem" bindtap="showTopTaskEdit">
        <view class="reduceIcon">🎯</view>
        <view class="reduceContent">
          <text class="reduceTitle">今日最重要1件事</text>
          <text class="reduceDesc">{{topTask ? topTask.text : '点击设置'}}</text>
        </view>
      </view>
      <!-- 拒绝话术 -->
      <view class="reduceItem" bindtap="goRefusalScripts">
        <view class="reduceIcon">💬</view>
        <view class="reduceContent">
          <text class="reduceTitle">拒绝话术</text>
          <text class="reduceDesc">学会说「不」</text>
        </view>
        <text class="reduceArrow">›</text>
      </view>
    </view>
  </view>

  <!-- 今日治愈模块 -->
  <view class="healingSection cardSurface">
    <view class="healingHeader">
      <text class="sectionTitle">今日治愈</text>
      <view class="healingAudioEntry" bindtap="goHealingAudio">
        <text class="healingAudioText">治愈音频</text>
        <text class="healingAudioArrow">›</text>
      </view>
    </view>
    
    <view wx:if="{{healingQuote}}" class="healingQuote">
      <text class="quoteText">{{healingQuote.quote}}</text>
    </view>
    
    <view class="healingActions">
      <view class="healingBtn" bindtap="goBreathing">
        <text class="healingBtnIcon">🌬️</text>
        <text class="healingBtnText">1分钟呼吸放松</text>
      </view>
    </view>
  </view>

  <view class="moodBar cardSurface">
    <view class="row">
      <text class="sectionTitle">今日情绪</text>
      <text wx:if="{{selectedMood}}" class="picked">已标记：{{selectedMood}}</text>
    </view>
    <view class="tagRow">
      <view
        wx:for="{{moodTags}}"
        wx:key="*this"
        class="tag {{selectedMood === item ? 'active' : ''}}"
        bindtap="onMoodTap"
        data-tag="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="section cardSurface">
    <text class="sectionTitle">一键吐槽</text>
    <view class="presetGrid">
      <button
        wx:for="{{presets}}"
        wx:key="key"
        class="presetBtn btnClean"
        bindtap="onPresetTap"
        data-key="{{item.key}}"
      >
        {{item.label}}
      </button>
    </view>
  </view>

  <view wx:if="{{card}}" class="cardWrap cardSurface">
    <view class="card">
      <view class="memeBox">
        <image
          wx:if="{{card.meme.type === 'image'}}"
          class="memeImg"
          src="{{card.meme.url}}"
          mode="aspectFit"
        />
        <text wx:else class="memeEmoji">{{card.meme.value}}</text>
      </view>
      <text class="cardText">{{card.text}}</text>
      <text class="cardFooter">今日嘴硬 · 安全发泄区</text>
    </view>

    <view class="actions">
      <button class="actionBtn btnMintGhost btnClean" bindtap="onSaveImage">保存</button>
      <button class="actionBtn btnMintPrimary btnClean" open-type="share">公开分享</button>
      <button class="actionBtn btnMintGhost btnClean" bindtap="onPrivateShare">私密</button>
    </view>
  </view>

  <view class="wallEntry cardSurface" bindtap="goWall">
    <view class="wallText">
      <text class="wallTitle">嘴硬墙</text>
      <text class="wallSub">匿名吐槽列表 · 仅展示文本</text>
    </view>
    <text class="wallArrow">›</text>
  </view>

  <canvas type="2d" id="shareCanvas" class="hiddenCanvas"></canvas>

  <!-- 设置今日最重要事项弹窗 -->
  <view wx:if="{{showTopTaskInput}}" class="modalMask" bindtap="hideTopTaskEdit">
    <view class="modalContent" catchtap="">
      <text class="modalTitle">今日最重要1件事</text>
      <input 
        class="modalInput"
        placeholder="输入内容，最多20字"
        maxlength="20"
        value="{{topTaskInputValue}}"
        bindinput="onTopTaskInput"
        focus="{{showTopTaskInput}}"
      />
      <view class="modalActions">
        <button wx:if="{{topTask}}" class="modalBtn deleteBtn btnClean" bindtap="removeTopTask">删除</button>
        <button class="modalBtn cancelBtn btnClean" bindtap="hideTopTaskEdit">取消</button>
        <button class="modalBtn confirmBtn btnClean" bindtap="saveTopTask">保存</button>
      </view>
    </view>
  </view>
</view>

