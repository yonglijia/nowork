/**
 * 治愈音频页面样式
 * 清晰、舒适、易操作
 */

.page {
  min-height: 100vh;
  background: #F5F8FA;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 180rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F5F9FF 100%);
  border-radius: 0 0 20rpx 20rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.favEntry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.favEntryText {
  font-size: 24rpx;
  color: #85929E;
}

.favEntryArrow {
  font-size: 26rpx;
  color: #9AA5B1;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  background: #ffffff;
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(92, 155, 214, 0.12);
}

.searchInput {
  font-size: 26rpx;
  color: #34495E;
}

.searchInput::placeholder {
  color: #9AA5B1;
}

/* ==================== 分类栏 ==================== */
.categoryBar {
  padding: 16rpx 0;
}

.categoryScroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.categoryItem {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #5D6D7E;
  background: #ffffff;
  border: 1rpx solid rgba(92, 155, 214, 0.12);
}

.categoryItem.active {
  background: #5C9BD6;
  border-color: #5C9BD6;
  color: #ffffff;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.loadingText,
.emptyText {
  font-size: 26rpx;
  color: #85929E;
}

.emptyIcon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
  opacity: 0.5;
}

/* ==================== 音频列表 ==================== */
.audioList {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 0 24rpx;
}

.audioItem {
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 14rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.04);
}

.audioItem.active {
  background: #E3F2FD;
  border: 1rpx solid rgba(92, 155, 214, 0.2);
}

.audioIcon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #5D6D7E;
}

.audioItem.active .audioIcon {
  background: #5C9BD6;
  color: #ffffff;
}

.audioContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.audioTitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.audioDesc {
  font-size: 22rpx;
  color: #85929E;
}

.audioDuration {
  font-size: 20rpx;
  color: #9AA5B1;
}

.audioFav {
  padding: 10rpx;
  font-size: 32rpx;
  color: #C8D4DC;
}

.audioFav.favorited {
  color: #EBA0A0;
}

/* ==================== 播放器底栏 ==================== */
.playerBar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(44, 62, 80, 0.06);
}

.playerInfo {
  flex: 1;
  min-width: 180rpx;
}

.playerTitle {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E50;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.playerTime {
  font-size: 20rpx;
  color: #85929E;
}

.playerControls {
  display: flex;
  gap: 10rpx;
}

.playerBtn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #5D6D7E;
}

.playerBtn.active {
  background: #5C9BD6;
  color: #ffffff;
}

.playerSlider {
  width: 100%;
  margin-top: 6rpx;
}
