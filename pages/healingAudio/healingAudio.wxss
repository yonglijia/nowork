/**
 * 治愈音频页面样式
 * 柔和、舒适、易操作
 */

.page {
  min-height: 100vh;
  background: #F8FBFB;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 200rpx;
}

/* ==================== 顶部区域 ==================== */
.header {
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #F0F7FF 100%);
  border-radius: 0 0 24rpx 24rpx;
}

.headerRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D5A5C;
}

.favEntry {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.favEntryText {
  font-size: 24rpx;
  color: #8AA0A2;
}

.favEntryArrow {
  font-size: 28rpx;
  color: #A0B5B7;
}

/* ==================== 搜索栏 ==================== */
.searchBar {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid rgba(126, 189, 184, 0.15);
}

.searchInput {
  font-size: 28rpx;
  color: #4A6B6E;
}

.searchInput::placeholder {
  color: #A0B5B7;
}

/* ==================== 分类栏 ==================== */
.categoryBar {
  padding: 20rpx 0;
}

.categoryScroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.categoryItem {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #5A8A8D;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(126, 189, 184, 0.15);
}

.categoryItem.active {
  background: #7EBDB8;
  border-color: #7EBDB8;
  color: #ffffff;
}

/* ==================== 加载和空状态 ==================== */
.loadingWrap,
.emptyWrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loadingText,
.emptyText {
  font-size: 28rpx;
  color: #8AA0A2;
}

.emptyIcon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

/* ==================== 音频列表 ==================== */
.audioList {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.audioItem {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 90, 92, 0.04);
}

.audioItem.active {
  background: rgba(126, 189, 184, 0.08);
  border: 2rpx solid rgba(126, 189, 184, 0.2);
}

.audioIcon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(126, 189, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #5A8A8D;
}

.audioItem.active .audioIcon {
  background: #7EBDB8;
  color: #ffffff;
}

.audioContent {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.audioTitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A5C;
}

.audioDesc {
  font-size: 24rpx;
  color: #8AA0A2;
}

.audioDuration {
  font-size: 22rpx;
  color: #A0B5B7;
}

.audioFav {
  padding: 12rpx;
  font-size: 36rpx;
  color: #C8D8D8;
}

.audioFav.favorited {
  color: #EBA0A0;
}

/* ==================== 播放器底栏 ==================== */
.playerBar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 24rpx rgba(61, 90, 92, 0.08);
}

.playerInfo {
  flex: 1;
  min-width: 200rpx;
}

.playerTitle {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3D5A5C;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.playerTime {
  font-size: 22rpx;
  color: #8AA0A2;
}

.playerControls {
  display: flex;
  gap: 12rpx;
}

.playerBtn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(126, 189, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #5A8A8D;
}

.playerBtn.active {
  background: #7EBDB8;
  color: #ffffff;
}

.playerSlider {
  width: 100%;
  margin-top: 8rpx;
}
